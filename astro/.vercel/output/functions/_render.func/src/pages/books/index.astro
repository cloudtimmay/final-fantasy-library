---
import Base from '../../layouts/Base.astro'
import { sanity, SHARED_FIELDS } from '../../lib/sanity'

const books = await sanity.fetch(`
  *[_type == "book"] | order(author asc, title asc) {
    _id, title, author, year, genre, readStatus, ${SHARED_FIELDS}
  }
`)
---
<Base title="Books">
  <div class="page-header">
    <h1>Books</h1>
    <span class="count">{books.length} items</span>
  </div>

  <div class="grid">
    {books.map((b: any) => (
      <a class="card" href={`/books/${b._id}`}>
        {b.photoUrl
          ? <img class="card-photo" src={b.photoUrl} alt={b.title} loading="lazy" />
          : <div class="card-photo-placeholder">📚</div>
        }
        <div class="card-title">{b.title}</div>
        <div class="card-sub">{b.author}{b.year ? ` · ${b.year}` : ''}</div>
        <div class="card-meta">
          <span class={`status-dot ${b.status}`}></span>
          {b.readStatus && <span class="tag">{b.readStatus}</span>}
          {b.rating && <span class="rating">{b.rating}/10</span>}
        </div>
      </a>
    ))}
  </div>
</Base>
