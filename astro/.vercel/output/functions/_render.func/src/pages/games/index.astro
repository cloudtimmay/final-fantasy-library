---
import Base from '../../layouts/Base.astro'
import { sanity, SHARED_FIELDS } from '../../lib/sanity'

const games = await sanity.fetch(`
  *[_type == "game"] | order(title asc) {
    _id, title, developer, year, platform, genre, completionStatus, ${SHARED_FIELDS}
  }
`)
---
<Base title="Games">
  <div class="page-header">
    <h1>Games</h1>
    <span class="count">{games.length} items</span>
  </div>

  <div class="grid">
    {games.map((g: any) => (
      <a class="card" href={`/games/${g._id}`}>
        {g.photoUrl
          ? <img class="card-photo" src={g.photoUrl} alt={g.title} loading="lazy" />
          : <div class="card-photo-placeholder">🎮</div>
        }
        <div class="card-title">{g.title}</div>
        <div class="card-sub">{g.platform?.join(', ')}{g.year ? ` · ${g.year}` : ''}</div>
        <div class="card-meta">
          <span class={`status-dot ${g.status}`}></span>
          {g.completionStatus && <span class="tag">{g.completionStatus}</span>}
          {g.rating && <span class="rating">{g.rating}/10</span>}
        </div>
      </a>
    ))}
  </div>
</Base>
