---
interface Props {
  title?: string
}
const { title = 'My Collection' } = Astro.props

const path = Astro.url.pathname
function isActive(href: string) {
  if (href === '/') return path === '/'
  return path === href || path.startsWith(href + '/')
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Collection</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Inter:wght@400;500;700&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --bg:       #0c0910;
      --surface:  #1c1420;
      --border:   #3a2230;
      --text:     #f0e9ec;
      --muted:    #9a8290;
      --accent:   #f4a24c;
      --accent-2: #b01e34;
      --owned:    #4caf80;
      --wishlist: #6b9fd4;
      --sold:     #7a7a8c;
      --lent:     #d4956b;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-size: 15px;
      line-height: 1.6;
      min-height: 100vh;
      overflow-x: hidden;
      background-color: #0c0910;
      background-image:
        radial-gradient(120% 80% at 50% 100%, rgba(244,162,76,0.22) 0%, rgba(244,162,76,0.06) 20%, transparent 42%),
        radial-gradient(110% 75% at 50% 72%, rgba(150,20,32,0.42) 0%, rgba(120,16,26,0.20) 40%, transparent 62%),
        linear-gradient(180deg, #0c0910 0%, #2a0d16 40%, #4a0f1c 66%, #17070d 100%);
      background-attachment: fixed;
      background-repeat: no-repeat;
    }
    a { color: inherit; text-decoration: none; }
    code, .mono { font-family: 'IBM Plex Mono', monospace; }

    nav {
      border-bottom: 1px solid var(--border);
      padding: 0.5rem 2rem;
      display: flex;
      align-items: center;
      gap: 1.25rem;
      flex-wrap: wrap;
      min-height: 56px;
      background: rgba(12,9,16,0.74);
      backdrop-filter: blur(10px);
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .nav-brand {
      font-family: 'IBM Plex Mono', monospace;
      font-weight: 600;
      font-size: 14px;
      color: var(--accent);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-right: auto;
    }
    nav a {
      font-size: 13px;
      color: var(--muted);
      font-weight: 500;
      letter-spacing: 0.02em;
      padding: 4px 0;
      border-bottom: 2px solid transparent;
      transition: color 0.15s, border-color 0.15s;
    }
    nav a:hover, nav a.active { color: var(--text); border-bottom-color: var(--accent); }
    nav a.nav-add { color: var(--accent); font-weight: 600; }

    .nav-search { display: flex; align-items: center; gap: 0.4rem; }
    .nav-search input {
      background: var(--surface);
      color: var(--text);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.35rem 0.6rem;
      font-size: 13px;
      width: 150px;
      transition: width 0.15s, border-color 0.15s;
    }
    .nav-search input:focus { outline: none; border-color: var(--accent); width: 190px; }
    .nav-search .scan-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.3rem 0.5rem;
      font-size: 15px;
      line-height: 1;
    }
    .nav-search .scan-link:hover { border-color: var(--accent); }

    main { max-width: 1200px; margin: 0 auto; padding: 2rem; position: relative; z-index: 1; }

    .bottom-nav { display: none; }

    .page-header {
      margin-bottom: 2rem;
      display: flex;
      align-items: baseline;
      gap: 1rem;
    }
    .page-header h1 { font-size: 1.5rem; font-weight: 700; letter-spacing: 0.01em; }
    .count { font-family: 'IBM Plex Mono', monospace; font-size: 12px; color: var(--muted); }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1px;
      background: var(--border);
    }
    .card {
      background: var(--surface);
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      transition: background 0.15s;
      cursor: pointer;
    }
    .card:hover { background: #241826; }
    .card-title { font-weight: 600; font-size: 14px; line-height: 1.3; }
    .card-sub { font-size: 12px; color: var(--muted); }
    .card-meta { margin-top: auto; display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    .status-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
    .status-dot.owned    { background: var(--owned); }
    .status-dot.wishlist { background: var(--wishlist); }
    .status-dot.sold     { background: var(--sold); }
    .status-dot.lent     { background: var(--lent); }

    .rating { font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: var(--accent); }
    .tag {
      font-size: 10px;
      font-family: 'IBM Plex Mono', monospace;
      background: var(--border);
      color: var(--muted);
      padding: 2px 6px;
      border-radius: 2px;
    }

    .card-photo {
      width: 100%;
      height: 180px !important;
      aspect-ratio: auto !important;
      object-fit: contain !important;
      background: var(--border);
      margin-bottom: 0.25rem;
    }
    .card-photo-placeholder {
      width: 100%;
      aspect-ratio: 1;
      background: var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      margin-bottom: 0.25rem;
    }

    .detail { max-width: 640px; }
    .detail h1 { font-size: 1.75rem; font-weight: 700; margin-bottom: 0.25rem; }
    .detail-sub { color: var(--muted); margin-bottom: 1.5rem; }
    .detail-photo {
      width: 100%;
      max-height: 400px;
      object-fit: contain;
      background: var(--surface);
      border: 1px solid var(--border);
      margin-bottom: 1.5rem;
    }
    .meta-table { border-collapse: collapse; width: 100%; }
    .meta-table td { padding: 0.5rem 0; border-bottom: 1px solid var(--border); font-size: 14px; }
    .meta-table td:first-child { color: var(--muted); width: 40%; font-family: 'IBM Plex Mono', monospace; font-size: 12px; }
    .notes-block {
      margin-top: 1.5rem;
      padding: 1rem;
      background: var(--surface);
      border-left: 3px solid var(--accent);
      font-size: 14px;
      color: var(--muted);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1px;
      background: var(--border);
      margin-bottom: 2rem;
    }
    .stat-card { background: var(--surface); padding: 1.5rem; }
    .stat-card .num {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 2.5rem;
      font-weight: 600;
      color: var(--accent);
      line-height: 1;
    }
    .stat-card .label {
      font-size: 12px;
      color: var(--muted);
      margin-top: 0.25rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    @media (max-width: 640px) {
      nav {
        padding: 0.5rem 1rem;
        gap: 0.75rem;
      }
      .nav-link { display: none; }
      .nav-search { flex: 1; }
      .nav-search input { width: 100%; }

      main {
        padding: 1rem;
        padding-bottom: 5rem;
      }
      .page-header h1 { font-size: 1.25rem; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .grid { grid-template-columns: 1fr; }

      .bottom-nav {
        display: flex;
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 20;
        background: #0c0910;
        border-top: 1px solid var(--border);
        padding: 0.4rem 0.5rem 0.6rem;
      }
      .bottom-nav a {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        padding: 0.4rem 0;
        font-size: 10px;
        color: var(--muted);
      }
      .bottom-nav a .bn-icon { font-size: 20px; line-height: 1; }
      .bottom-nav a.active { color: var(--accent); }
    }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="nav-brand">Collection</a>
    <a href="/scan" class:list={['nav-link', { active: isActive('/scan') }]}>🔍 Scan</a>
    <a href="/add" class:list={['nav-link', 'nav-add', { active: isActive('/add') }]}>+ Add</a>
    <a href="/notes" class:list={['nav-link', { active: isActive('/notes') }]}>Notes</a>
    <a href="/spending" class:list={['nav-link', { active: isActive('/spending') }]}>Spending</a>
    <a href="/wishlist" class:list={['nav-link', { active: isActive('/wishlist') }]}>Wishlist</a>
    <a href="/series" class:list={['nav-link', { active: isActive('/series') }]}>Series</a>
    <a href="/albums" class:list={['nav-link', { active: isActive('/albums') }]}>Albums</a>
    <a href="/games" class:list={['nav-link', { active: isActive('/games') }]}>Games</a>
    <a href="/figures" class:list={['nav-link', { active: isActive('/figures') }]}>Figures</a>
    <a href="/books" class:list={['nav-link', { active: isActive('/books') }]}>Books</a>
    <a href="/vgmdb" class:list={['nav-link', { active: isActive('/vgmdb') }]}>VGMdb</a>
    <a href="/export" class:list={['nav-link', { active: isActive('/export') }]}>Export</a>
    <form class="nav-search" method="get" action="/scan" role="search">
      <input type="search" name="q" placeholder="Search…" aria-label="Search collection" />
      <a href="/scan?scan=1" class="scan-link" title="Scan barcode" aria-label="Scan barcode">📷</a>
    </form>
  </nav>

  <main>
    <slot />
  </main>

  <nav class="bottom-nav">
    <a href="/" class:list={[{ active: path === '/' }]}><span class="bn-icon">🏠</span>Home</a>
    <a href="/scan" class:list={[{ active: isActive('/scan') }]}><span class="bn-icon">🔍</span>Scan</a>
    <a href="/add" class:list={[{ active: isActive('/add') }]}><span class="bn-icon">➕</span>Add</a>
    <a href="/spending" class:list={[{ active: isActive('/spending') }]}><span class="bn-icon">💴</span>Spending</a>
    <a href="/wishlist" class:list={[{ active: isActive('/wishlist') }]}><span class="bn-icon">⭐</span>Wishlist</a>
  </nav>
</body>
</html>