---
interface Props {
  title?: string
}
const { title = 'My Collection' } = Astro.props
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Collection</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Inter:wght@400;500;700&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --bg:       #0f0f11;
      --surface:  #1a1a1f;
      --border:   #2a2a33;
      --text:     #e8e8f0;
      --muted:    #7a7a8c;
      --accent:   #c8a96e;   /* warm amber — catalogue/archive feel */
      --owned:    #4caf80;
      --wishlist: #6b9fd4;
      --sold:     #7a7a8c;
      --lent:     #d4956b;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-size: 15px;
      line-height: 1.6;
      min-height: 100vh;
      overflow-x: hidden;
    }
    a { color: inherit; text-decoration: none; }
    code, .mono { font-family: 'IBM Plex Mono', monospace; }

    /* Nav */
    nav {
      border-bottom: 1px solid var(--border);
      padding: 0.5rem 2rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      flex-wrap: wrap;
      min-height: 56px;
    }
    .nav-brand {
      font-family: 'IBM Plex Mono', monospace;
      font-weight: 600;
      font-size: 14px;
      color: var(--accent);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-right: auto;
    }
    nav a {
      font-size: 13px;
      color: var(--muted);
      font-weight: 500;
      letter-spacing: 0.02em;
      padding: 4px 0;
      border-bottom: 2px solid transparent;
      transition: color 0.15s, border-color 0.15s;
    }
    nav a:hover, nav a.active { color: var(--text); border-bottom-color: var(--accent); }

    /* Main */
    main { max-width: 1200px; margin: 0 auto; padding: 2rem; }

    /* Page header */
    .page-header {
      margin-bottom: 2rem;
      display: flex;
      align-items: baseline;
      gap: 1rem;
    }
    .page-header h1 {
      font-size: 1.5rem;
      font-weight: 700;
    }
    .count {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 12px;
      color: var(--muted);
    }

    /* Grid */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1px;
      background: var(--border);
    }
    .card {
      background: var(--surface);
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      transition: background 0.15s;
      cursor: pointer;
    }
    .card:hover { background: #22222a; }
    .card-title {
      font-weight: 600;
      font-size: 14px;
      line-height: 1.3;
    }
    .card-sub {
      font-size: 12px;
      color: var(--muted);
    }
    .card-meta {
      margin-top: auto;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .status-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .status-dot.owned    { background: var(--owned); }
    .status-dot.wishlist { background: var(--wishlist); }
    .status-dot.sold     { background: var(--sold); }
    .status-dot.lent     { background: var(--lent); }

    .rating {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      color: var(--accent);
    }
    .tag {
      font-size: 10px;
      font-family: 'IBM Plex Mono', monospace;
      background: var(--border);
      color: var(--muted);
      padding: 2px 6px;
      border-radius: 2px;
    }

    /* Photo thumbnail */
    .card-photo {
      width: 100%;
      height: 180px !important;
      aspect-ratio: auto !important;
      object-fit: contain !important;
      background: var(--border);
      margin-bottom: 0.25rem;
    }
    .card-photo-placeholder {
      width: 100%;
      aspect-ratio: 1;
      background: var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      margin-bottom: 0.25rem;
    }

    /* Detail page */
    .detail { max-width: 640px; }
    .detail h1 { font-size: 1.75rem; font-weight: 700; margin-bottom: 0.25rem; }
    .detail-sub { color: var(--muted); margin-bottom: 1.5rem; }
    .detail-photo {
      width: 100%;
      max-height: 400px;
      object-fit: contain;
      background: var(--surface);
      border: 1px solid var(--border);
      margin-bottom: 1.5rem;
    }
    .meta-table { border-collapse: collapse; width: 100%; }
    .meta-table td { padding: 0.5rem 0; border-bottom: 1px solid var(--border); font-size: 14px; }
    .meta-table td:first-child { color: var(--muted); width: 40%; font-family: 'IBM Plex Mono', monospace; font-size: 12px; }
    .notes-block {
      margin-top: 1.5rem;
      padding: 1rem;
      background: var(--surface);
      border-left: 3px solid var(--accent);
      font-size: 14px;
      color: var(--muted);
    }

    /* Dashboard */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1px;
      background: var(--border);
      margin-bottom: 2rem;
    }
    .stat-card {
      background: var(--surface);
      padding: 1.5rem;
    }
    .stat-card .num {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 2.5rem;
      font-weight: 600;
      color: var(--accent);
      line-height: 1;
    }
    .stat-card .label {
      font-size: 12px;
      color: var(--muted);
      margin-top: 0.25rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    /* Mobil */
    @media (max-width: 640px) {
      nav {
        padding: 0.5rem 1rem;
        gap: 1rem;
      }
      main {
        padding: 1rem;
      }
      .page-header h1 {
        font-size: 1.25rem;
      }
      .stats-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="nav-brand">Collection</a>
    <a href="/scan">🔍 Scan</a>
    <a href="/wishlist">Wishlist</a>
    <a href="/albums">Albums</a>
    <a href="/games">Games</a>
    <a href="/figures">Figures</a>
    <a href="/books">Books</a>
    <a href="/vgmdb">VGMdb</a>
    <a href="/books-lookup">Bok-oppslag</a>
    <a href="/export">Export</a>
  </nav>
  <main>
    <slot />
  </main>
</body>
</html>
