---
import Base from '../layouts/Base.astro'
import { sanity } from '../lib/sanity'

const trips = await sanity.fetch(`
  *[_type == "tripSettings"] | order(_createdAt asc) {
    _id, label, childBudgets[]{ person }
  }
`)

const stores = await sanity.fetch(`
  *[_type == "shopNote" && !(_id in path("drafts.**"))] | order(shopName asc) {
    _id, shopName, area
  }
`)

const today = new Date().toISOString().split('T')[0]
---
<Base title="Add family purchase">
  <div class="add-wrap">
    <h1>Add family purchase</h1>
    <p class="hint">Register a purchase for the trip budget. Trip and store stay selected so you can add several in a row.</p>

    <div class="field">
      <label>Trip *</label>
      <select id="f-trip"></select>
    </div>

    <div class="field">
      <label>Person *</label>
      <select id="f-person"></select>
    </div>

    <div class="field">
      <label>Name *</label>
      <input id="f-name" type="text" placeholder="What is it?" />
    </div>

    <div class="field-row">
      <div class="field">
        <label>Price (JPY)</label>
        <input id="f-yen" type="number" inputmode="numeric" placeholder="¥" />
      </div>
      <div class="field">
        <label>Price (NOK)</label>
        <input id="f-nok" type="number" inputmode="numeric" placeholder="kr" />
      </div>
    </div>

    <div class="field">
      <label>Store</label>
      <select id="f-store"></select>
      <a href="/add-store" class="add-store-link">+ Add a new shop</a>
    </div>

    <div class="field-row">
      <div class="field">
        <label>Date</label>
        <input id="f-date" type="date" value={today} />
      </div>
      <div class="field">
        <label>Status</label>
        <select id="f-status">
          <option value="planned">Planned</option>
          <option value="bought">Bought</option>
        </select>
      </div>
    </div>

    <div class="field">
      <label>Barcode</label>
      <div class="barcode-row">
        <input id="f-barcode" type="text" placeholder="Scanned code (optional)" />
        <button id="f-scan" type="button" class="scan-btn">📷 Scan</button>
      </div>
      <div id="f-reader" class="scan-reader" hidden></div>
      <p id="f-scan-msg" class="scan-msg" hidden></p>
      <div id="f-dup" class="dup-warn" hidden></div>
    </div>

    <div class="field">
      <label>Photo / receipt (optional)</label>
      <div class="photo-buttons">
        <label class="upload-btn">
          📷 Take photo
          <input id="f-photo-camera" type="file" accept="image/*" capture="environment" hidden />
        </label>
        <label class="upload-btn">
          🖼️ Choose from gallery
          <input id="f-photo-gallery" type="file" accept="image/*" hidden />
        </label>
      </div>
      <span id="f-photo-name" class="photo-name" hidden></span>
      <img id="f-preview" class="photo-preview" hidden alt="Preview" />
    </div>

    <button id="f-save" type="button" class="save-btn">Save purchase</button>
    <p id="f-msg" class="save-msg" hidden></p>

    <a href="/scan" class="back-link">← Back to scan</a>
  </div>

  <script is:inline src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>

  <script define:vars={{ trips, stores }}>
    const tripSel = document.querySelector('#f-trip')
    const personSel = document.querySelector('#f-person')
    const storeSel = document.querySelector('#f-store')
    const nameInput = document.querySelector('#f-name')
    const yenInput = document.querySelector('#f-yen')
    const nokInput = document.querySelector('#f-nok')
    const dateInput = document.querySelector('#f-date')
    const statusSel = document.querySelector('#f-status')
    const barcodeInput = document.querySelector('#f-barcode')
    const saveBtn = document.querySelector('#f-save')
    const msg = document.querySelector('#f-msg')

    const scanBtn = document.querySelector('#f-scan')
    const reader = document.querySelector('#f-reader')
    const scanMsg = document.querySelector('#f-scan-msg')
    const dupWarn = document.querySelector('#f-dup')

    const photoCamera = document.querySelector('#f-photo-camera')
    const photoGallery = document.querySelector('#f-photo-gallery')
    const photoName = document.querySelector('#f-photo-name')
    const preview = document.querySelector('#f-preview')
    let selectedPhoto = null

    function handlePhoto(fileInput) {
      const file = fileInput.files && fileInput.files[0]
      if (!file) return
      selectedPhoto = file
      photoName.hidden = false
      photoName.textContent = file.name
      preview.hidden = false
      preview.src = URL.createObjectURL(file)
    }
    photoCamera.addEventListener('change', () => handlePhoto(photoCamera))
    photoGallery.addEventListener('change', () => handlePhoto(photoGallery))

    // Prefill barcode from ?barcode=... when arriving from /scan
    const params = new URLSearchParams(window.location.search)
    const preBarcode = params.get('barcode')
    if (preBarcode) barcodeInput.value = preBarcode

    tripSel.innerHTML = '<option value="">Select trip…</option>' +
      trips.map((t) => `<option value="${t._id}">${t.label || 'Trip'}</option>`).join('')

    storeSel.innerHTML = '<option value="">No store</option>' +
      stores.map((s) => `<option value="${s._id}">${s.shopName}${s.area ? ' (' + s.area + ')' : ''}</option>`).join('')

    function refreshPeople() {
      const trip = trips.find((t) => t._id === tripSel.value)
      const people = trip ? (trip.childBudgets || []).map((c) => c.person).filter(Boolean) : []
      personSel.innerHTML = '<option value="">Select person…</option>' +
        [...new Set(people)].map((p) => `<option value="${p}">${p}</option>`).join('')
    }
    tripSel.addEventListener('change', refreshPeople)
    refreshPeople()

    function showMsg(text, ok) {
      msg.hidden = false
      msg.textContent = text
      msg.style.color = ok ? '#2ecc71' : '#e74c3c'
    }

    async function checkDuplicate(code) {
      dupWarn.hidden = true
      dupWarn.innerHTML = ''
      const c = (code || '').trim()
      if (!c) return
      try {
        const res = await fetch('/api/check-duplicate?barcode=' + encodeURIComponent(c))
        const data = await res.json()
        if (res.ok && data.count > 0) {
          const m = data.matches[0]
          dupWarn.hidden = false
          dupWarn.innerHTML = `⚠️ <strong>Already in your collection:</strong> “${m.title}” (${m.status || m._type}).`
        }
      } catch {
        // Silent — duplicate check is a nice-to-have, not a blocker.
      }
    }

    barcodeInput.addEventListener('change', () => checkDuplicate(barcodeInput.value))
    if (preBarcode) checkDuplicate(preBarcode)

    let scanner = null
    let running = false

    async function startScan() {
      if (typeof Html5Qrcode === 'undefined') {
        scanMsg.hidden = false
        scanMsg.textContent = 'Scanner could not be loaded. Check your connection.'
        return
      }
      reader.hidden = false
      scanMsg.hidden = true
      scanner = new Html5Qrcode('f-reader')
      try {
        await scanner.start(
          { facingMode: 'environment' },
          { fps: 10, qrbox: { width: 250, height: 150 } },
          (decodedText) => {
            const code = decodedText.replace(/[^0-9Xx]/g, '')
            barcodeInput.value = code
            stopScan()
            checkDuplicate(code)
          },
          () => {}
        )
        running = true
        scanBtn.textContent = '✕ Close'
      } catch (err) {
        scanMsg.hidden = false
        scanMsg.textContent = 'Could not access camera. Allow camera and try again.'
        reader.hidden = true
      }
    }

    async function stopScan() {
      if (scanner && running) {
        try { await scanner.stop() } catch (e) {}
        running = false
      }
      reader.hidden = true
      scanBtn.textContent = '📷 Scan'
    }

    scanBtn.addEventListener('click', () => {
      if (running) stopScan()
      else startScan()
    })

    async function save() {
      if (!tripSel.value) return showMsg('Please select a trip.', false)
      if (!personSel.value) return showMsg('Please select a person.', false)
      if (!nameInput.value.trim()) return showMsg('Please enter a name.', false)

      saveBtn.disabled = true
      saveBtn.textContent = 'Saving…'

      try {
        const res = await fetch('/api/family-purchase', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: nameInput.value.trim(),
            person: personSel.value,
            tripId: tripSel.value,
            storeId: storeSel.value || undefined,
            priceYen: yenInput.value,
            priceNok: nokInput.value,
            purchaseDate: dateInput.value,
            status: statusSel.value,
            barcode: barcodeInput.value.trim() || undefined,
          }),
        })
        const data = await res.json()
        if (!res.ok) {
          showMsg(data.error || 'Save failed.', false)
          return
        }

        // Upload the photo (to the photos array) if one was chosen.
        if (selectedPhoto && data.id) {
          saveBtn.textContent = 'Uploading photo…'
          const form = new FormData()
          form.append('file', selectedPhoto)
          form.append('docId', data.id)
          form.append('field', 'photos')
          try {
            await fetch('/api/upload-image', { method: 'POST', body: form })
          } catch {}
        }

        showMsg('Saved ✓ — ready for the next one.', true)

        nameInput.value = ''
        yenInput.value = ''
        nokInput.value = ''
        barcodeInput.value = ''
        statusSel.value = 'planned'
        selectedPhoto = null
        photoCamera.value = ''
        photoGallery.value = ''
        photoName.hidden = true
        preview.hidden = true
        preview.src = ''
        dupWarn.hidden = true
        dupWarn.innerHTML = ''
        nameInput.focus()
      } catch (e) {
        showMsg('Network error.', false)
      } finally {
        saveBtn.disabled = false
        saveBtn.textContent = 'Save purchase'
      }
    }

    saveBtn.addEventListener('click', save)
  </script>

  <style>
    .add-wrap { max-width: 520px; }
    .hint { font-size: 0.9rem; color: var(--muted); margin: 0.25rem 0 1.5rem; }
    .field { margin-bottom: 1rem; }
    .field-row { display: flex; gap: 1rem; }
    .field-row .field { flex: 1; }
    .field label { display: block; font-size: 0.8rem; color: var(--muted); margin-bottom: 0.35rem; }
    .field input, .field select {
      width: 100%; background: var(--surface); color: var(--text);
      border: 1px solid var(--border); padding: 0.7rem 0.75rem; border-radius: 8px; font-size: 1rem;
    }
    .add-store-link { display: inline-block; margin-top: 0.4rem; font-size: 0.85rem; color: var(--accent); text-decoration: none; }
    .add-store-link:hover { text-decoration: underline; }
    .barcode-row { display: flex; gap: 0.5rem; }
    .barcode-row input { flex: 1; min-width: 0; }
    .scan-btn {
      flex-shrink: 0; background: var(--surface); color: var(--text); border: 1px solid var(--accent);
      padding: 0 1rem; border-radius: 8px; cursor: pointer; font-size: 0.9rem; white-space: nowrap;
    }
    .scan-reader { width: 100%; max-width: 400px; margin: 0.75rem auto 0; border-radius: 8px; overflow: hidden; }
    .scan-msg { font-size: 0.85rem; color: var(--muted); margin: 0.5rem 0 0; }
    .dup-warn {
      background: #4a0f1c; border: 1px solid #e74c3c; color: #ffd9d9;
      padding: 0.7rem 0.85rem; border-radius: 8px; margin-top: 0.6rem; font-size: 0.9rem;
    }
    .dup-warn strong { color: #fff; }
    .photo-buttons { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .upload-btn {
      display: inline-block; background: var(--surface); color: var(--text);
      border: 1px solid var(--accent); padding: 0.6rem 0.9rem; border-radius: 8px;
      cursor: pointer; font-size: 0.9rem;
    }
    .upload-btn:hover { background: #241826; }
    .photo-name { font-size: 0.85rem; color: var(--muted); display: block; margin-top: 0.5rem; }
    .photo-preview { display: block; max-width: 200px; max-height: 200px; margin-top: 0.75rem; border-radius: 8px; border: 1px solid var(--border); }
    .save-btn {
      width: 100%; margin-top: 0.5rem; background: var(--accent); color: #fff; border: none;
      padding: 0.9rem; border-radius: 8px; font-size: 1.05rem; font-weight: 600; cursor: pointer;
    }
    .save-btn:disabled { opacity: 0.6; cursor: default; }
    .save-msg { font-size: 0.9rem; margin: 0.75rem 0 0; }
    .back-link { display: inline-block; margin-top: 1.5rem; color: var(--muted); text-decoration: none; font-size: 0.9rem; }
    .back-link:hover { color: var(--accent); }
  </style>
</Base>