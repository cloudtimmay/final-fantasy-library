---
import Base from '../../layouts/Base.astro'
import { sanity, SHARED_FIELDS, urlFor } from '../../lib/sanity'

const { id } = Astro.params

const a = await sanity.fetch(
  `*[_type == "album" && _id == $id][0] {
    title, artist, composer, year, genre, format, label,
    catalogNumber, vgmdbId, vgmdbUrl, externalImageUrl, youtubeMusicUrl, youtubePlaylistId,
    tracklist[]{ disc, trackNumber, title, duration, youtubeId },
    ${SHARED_FIELDS}
  }`,
  { id }
)

if (!a) return Astro.redirect('/albums')

function ytId(raw) {
  if (!raw) return ''
  const s = String(raw).trim()
  const match = s.match(/(?:v=|youtu\.be\/|embed\/)([A-Za-z0-9_-]{11})/)
  if (match) return match[1]
  if (/^[A-Za-z0-9_-]{11}$/.test(s)) return s
  return ''
}

function ytPlaylistId(raw) {
  if (!raw) return ''
  const s = String(raw).trim()
  const listMatch = s.match(/[?&]list=([A-Za-z0-9_-]+)/)
  if (listMatch) return 'list:' + listMatch[1]
  const vid = ytId(s)
  if (vid) return 'video:' + vid
  if (/^PL[A-Za-z0-9_-]+$/.test(s)) return 'list:' + s
  return ''
}

const albumYt = ytPlaylistId(a.youtubePlaylistId)

const tracks = (a.tracklist || []).map((t) => ({ ...t, _yt: ytId(t.youtubeId) }))
const discMap = {}
for (const t of tracks) {
  const d = t.disc || 1
  if (!discMap[d]) discMap[d] = []
  discMap[d].push(t)
}
const discNumbers = Object.keys(discMap).map(Number).sort((x, y) => x - y)
const multiDisc = discNumbers.length > 1
---
<Base title={a.title}>
  <div class="detail">
    <a href="/albums" style="font-size:13px;color:var(--muted)">← Albums</a>
    <br /><br />
    <h1>{a.title}</h1>
    <div class="detail-sub">{a.artist}</div>

    {a.image
      ? <img class="detail-photo" src={urlFor(a.image).width(640).url()} alt={a.title} />
      : a.externalImageUrl
      ? <img class="detail-photo" src={a.externalImageUrl} alt={a.title} />
      : <div class="detail-photo placeholder">🎵</div>
    }

    <div class="upload-row">
      <label class="upload-btn">
        📷 Take photo
        <input id="img-camera" type="file" accept="image/*" capture="environment" hidden />
      </label>
      <label class="upload-btn">
        🖼️ Choose from gallery
        <input id="img-gallery" type="file" accept="image/*" hidden />
      </label>
      <span id="upload-msg" class="upload-msg" hidden></span>
    </div>

    <table class="meta-table">
      {a.composer  && <tr><td>Composer</td><td>{a.composer}</td></tr>}
      {a.year      && <tr><td>Year</td><td>{a.year}</td></tr>}
      {a.genre     && <tr><td>Genre</td><td>{a.genre}</td></tr>}
      {a.format    && <tr><td>Format</td><td>{a.format}</td></tr>}
      {a.label     && <tr><td>Label</td><td>{a.label}</td></tr>}
      {a.status    && <tr><td>Status</td><td>{a.status}</td></tr>}
      {a.rating    && <tr><td>Rating</td><td class="rating">{a.rating} / 10</td></tr>}
      {a.acquiredDate && <tr><td>Acquired</td><td>{a.acquiredDate}</td></tr>}
      {a.catalogNumber && <tr><td>Catalog</td><td>{a.catalogNumber}</td></tr>}
      {a.vgmdbUrl && <tr><td>VGMdb</td><td><a href={a.vgmdbUrl} target="_blank">Open VGMdb</a></td></tr>}
      {a.youtubeMusicUrl && <tr><td>YouTube Music</td><td><a href={a.youtubeMusicUrl} target="_blank" rel="noopener">▶ Spill av i YouTube Music</a></td></tr>}
      {a.purchasePrice && <tr><td>Paid</td><td>{a.purchasePrice} NOK</td></tr>}
    </table>

    {a.tags?.length > 0 && (
      <div style="margin-top:1rem;display:flex;gap:0.5rem;flex-wrap:wrap">
        {a.tags.map((t) => <span class="tag">{t}</span>)}
      </div>
    )}
    {a.notes && <div class="notes-block">{a.notes}</div>}

    {tracks.length > 0 && (
      <section class="tracklist">
        <h2>Tracklist <span class="track-count">{tracks.length} tracks</span></h2>

        <div class="album-play-row">
          {albumYt ? (
            <button class="album-play" data-yt={albumYt} title="Spill av hele albumet">▶ Spill av album</button>
          ) : (
            <a class="album-play" href={`https://www.youtube.com/results?search_query=${encodeURIComponent(a.title + ' ' + a.artist + ' full album')}`} target="_blank" rel="noopener">🔍 Søk album på YouTube</a>
          )}
        </div>

        {discNumbers.map((d) => (
          <div class="disc">
            {multiDisc && <div class="disc-title">Disc {d}</div>}
            <ol class="track-rows">
              {discMap[d].map((t) => (
                <li class="track-row">
                  <span class="track-num">{t.trackNumber}</span>
                  <span class="track-title">{t.title}</span>
                  {t.duration && <span class="track-time">{t.duration}</span>}
                  {t._yt ? (
                    <button class="track-play" data-yt={t._yt} title="Spill av">▶</button>
                  ) : (
                    <a class="track-search" href={`https://www.youtube.com/results?search_query=${encodeURIComponent(a.title + ' ' + t.title)}`} target="_blank" rel="noopener" title="Søk på YouTube">🔍</a>
                  )}
                </li>
              ))}
            </ol>
          </div>
        ))}

        <div id="yt-player" class="yt-player" hidden>
          <div class="yt-player-bar">
            <span id="yt-now"></span>
            <button id="yt-close" title="Lukk">✕</button>
          </div>
          <div class="yt-frame-wrap">
            <iframe id="yt-frame" src="" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
        </div>
      </section>
    )}
  </div>

  <style>
    .detail-photo.placeholder { display: flex; align-items: center; justify-content: center; font-size: 4rem; height: 280px; background: var(--surface); }
    .upload-row { display: flex; align-items: center; gap: 0.5rem; margin: 1rem 0 1.5rem; flex-wrap: wrap; }
    .upload-btn { display: inline-block; background: var(--surface); color: var(--text); border: 1px solid var(--accent); padding: 0.55rem 0.9rem; border-radius: 8px; cursor: pointer; font-size: 0.9rem; }
    .upload-btn:hover { background: #241826; }
    .upload-msg { font-size: 0.85rem; width: 100%; }

    .tracklist { margin-top: 2rem; border-top: 1px solid var(--border); padding-top: 1rem; }
    .tracklist h2 { font-size: 1rem; font-weight: 600; display: flex; align-items: baseline; gap: 0.75rem; }
    .track-count { font-size: 0.8rem; font-weight: 400; color: var(--muted); }
    .album-play-row { margin: 0.75rem 0 0.5rem; }
    .album-play { display: inline-flex; align-items: center; gap: 0.4rem; background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 0.5rem 0.9rem; color: var(--text); font-size: 0.85rem; cursor: pointer; text-decoration: none; }
    .album-play:hover { border-color: var(--accent); }
    .disc { margin-top: 1rem; }
    .disc-title { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); margin-bottom: 0.4rem; }
    .track-rows { list-style: none; margin: 0; padding: 0; }
    .track-row { display: flex; gap: 1rem; padding: 0.4rem 0; border-bottom: 1px solid var(--border); align-items: center; }
    .track-num { flex-shrink: 0; width: 2rem; text-align: right; color: var(--muted); font-variant-numeric: tabular-nums; }
    .track-title { flex: 1; min-width: 0; }
    .track-time { flex-shrink: 0; color: var(--muted); font-variant-numeric: tabular-nums; }
    .track-play, .track-search { flex-shrink: 0; width: 1.9rem; height: 1.9rem; display: flex; align-items: center; justify-content: center; background: var(--surface); border: 1px solid var(--border); border-radius: 6px; color: var(--text); font-size: 0.75rem; cursor: pointer; text-decoration: none; }
    .track-play:hover, .track-search:hover { border-color: var(--accent); }
    .yt-player { margin-top: 1.5rem; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; background: var(--surface); }
    .yt-player-bar { display: flex; align-items: center; justify-content: space-between; padding: 0.5rem 0.75rem; font-size: 0.85rem; gap: 1rem; }
    #yt-now { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    #yt-close { flex-shrink: 0; background: none; border: none; color: var(--muted); cursor: pointer; font-size: 1rem; }
    .yt-frame-wrap { position: relative; width: 100%; aspect-ratio: 16 / 9; }
    #yt-frame { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  </style>

  <script>
    const player = document.querySelector('#yt-player')
    const frame = document.querySelector('#yt-frame')
    const now = document.querySelector('#yt-now')
    const closeBtn = document.querySelector('#yt-close')

    function openPlayer(src, label) {
      frame.src = src
      now.textContent = label
      player.hidden = false
      player.scrollIntoView({ behavior: 'smooth', block: 'nearest' })
    }

    document.querySelectorAll('.track-play').forEach((btn) => {
      btn.addEventListener('click', () => {
        const ytId = btn.dataset.yt
        const row = btn.closest('.track-row')
        const title = row && row.querySelector('.track-title') ? row.querySelector('.track-title').textContent : ''
        openPlayer('https://www.youtube.com/embed/' + ytId + '?autoplay=1', title)
      })
    })

    const albumBtn = document.querySelector('.album-play[data-yt]')
    if (albumBtn) {
      albumBtn.addEventListener('click', () => {
        const val = albumBtn.dataset.yt
        let src = ''
        if (val.startsWith('list:')) {
          src = 'https://www.youtube.com/embed/videoseries?list=' + val.slice(5) + '&autoplay=1'
        } else if (val.startsWith('video:')) {
          src = 'https://www.youtube.com/embed/' + val.slice(6) + '?autoplay=1'
        }
        if (src) openPlayer(src, 'Hele albumet')
      })
    }

    closeBtn.addEventListener('click', () => {
      frame.src = ''
      player.hidden = true
    })

    // --- Image upload (camera or gallery) ---
    const camera = document.querySelector('#img-camera')
    const gallery = document.querySelector('#img-gallery')
    const uploadMsg = document.querySelector('#upload-msg')
    const detailPhoto = document.querySelector('.detail-photo')

    async function handleUpload(fileInput) {
      const file = fileInput.files && fileInput.files[0]
      if (!file) return

      uploadMsg.hidden = false
      uploadMsg.style.color = 'var(--muted)'
      uploadMsg.textContent = 'Uploading…'

      const form = new FormData()
      form.append('file', file)
      form.append('docId', window.location.pathname.split('/').pop())
      form.append('field', 'image')

      try {
        const res = await fetch('/api/upload-image', { method: 'POST', body: form })
        const data = await res.json()
        if (!res.ok) {
          uploadMsg.style.color = '#e74c3c'
          uploadMsg.textContent = data.error || 'Upload failed.'
          return
        }
        uploadMsg.style.color = '#2ecc71'
        uploadMsg.textContent = 'Uploaded ✓'
        if (detailPhoto && data.url) {
          const fresh = data.url + '?t=' + Date.now()
          if (detailPhoto.tagName === 'IMG') {
            detailPhoto.src = fresh
          } else {
            const img = document.createElement('img')
            img.className = 'detail-photo'
            img.src = fresh
            img.alt = document.querySelector('h1')?.textContent || ''
            detailPhoto.replaceWith(img)
          }
        }
      } catch {
        uploadMsg.style.color = '#e74c3c'
        uploadMsg.textContent = 'Network error.'
      }
    }

    if (camera) camera.addEventListener('change', () => handleUpload(camera))
    if (gallery) gallery.addEventListener('change', () => handleUpload(gallery))
  </script>
</Base>