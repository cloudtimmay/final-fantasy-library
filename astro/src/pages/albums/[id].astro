---
import Base from '../../layouts/Base.astro'
import { sanity, SHARED_FIELDS } from '../../lib/sanity'

const { id } = Astro.params

const a = await sanity.fetch(
  `*[_type == "album" && _id == $id][0] {
    title, artist, year, genre, format, label,
    catalogNumber, vgmdbId, vgmdbUrl, externalImageUrl,
    tracklist[]{ disc, trackNumber, title },
    ${SHARED_FIELDS}
  }`,
  { id }
)

if (!a) return Astro.redirect('/albums')

// Grupper spor per disk
const tracks = a.tracklist || []
const discMap: Record<number, any[]> = {}
for (const t of tracks) {
  const d = t.disc || 1
  ;(discMap[d] ||= []).push(t)
}
const discNumbers = Object.keys(discMap).map(Number).sort((x, y) => x - y)
const multiDisc = discNumbers.length > 1
---
<Base title={a.title}>
  <div class="detail">
    <a href="/albums" style="font-size:13px;color:var(--muted)">← Albums</a>
    <br /><br />
    <h1>{a.title}</h1>
    <div class="detail-sub">{a.artist}</div>

    {a.externalImageUrl && <img class="detail-photo" src={a.externalImageUrl} alt={a.title} />}

    <table class="meta-table">
      {a.year      && <tr><td>Year</td><td>{a.year}</td></tr>}
      {a.genre     && <tr><td>Genre</td><td>{a.genre}</td></tr>}
      {a.format    && <tr><td>Format</td><td>{a.format}</td></tr>}
      {a.label     && <tr><td>Label</td><td>{a.label}</td></tr>}
      {a.status    && <tr><td>Status</td><td>{a.status}</td></tr>}
      {a.rating    && <tr><td>Rating</td><td class="rating">{a.rating} / 10</td></tr>}
      {a.acquiredDate && <tr><td>Acquired</td><td>{a.acquiredDate}</td></tr>}
      {a.catalogNumber && <tr><td>Catalog</td><td>{a.catalogNumber}</td></tr>}
      {a.vgmdbUrl && <tr><td>VGMdb</td><td><a href={a.vgmdbUrl} target="_blank">Open VGMdb</a></td></tr>}
      {a.purchasePrice && <tr><td>Paid</td><td>{a.purchasePrice} NOK</td></tr>}
    </table>

    {a.tags?.length > 0 && (
      <div style="margin-top:1rem;display:flex;gap:0.5rem;flex-wrap:wrap">
        {a.tags.map((t: string) => <span class="tag">{t}</span>)}
      </div>
    )}
    {a.notes && <div class="notes-block">{a.notes}</div>}

    {tracks.length > 0 && (
      <section class="tracklist">
        <h2>Tracklist <span class="track-count">{tracks.length} tracks</span></h2>

        {discNumbers.map((d) => (
          <div class="disc">
            {multiDisc && <div class="disc-title">Disc {d}</div>}
            <ol class="track-rows">
              {discMap[d].map((t: any) => (
                <li class="track-row">
                  <span class="track-num">{t.trackNumber}</span>
                  <span class="track-title">{t.title}</span>
                </li>
              ))}
            </ol>
          </div>
        ))}
      </section>
    )}
  </div>

  <style>
    .tracklist {
      margin-top: 2rem;
      border-top: 1px solid var(--border);
      padding-top: 1rem;
    }

    .tracklist h2 {
      font-size: 1rem;
      font-weight: 600;
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
    }

    .track-count {
      font-size: 0.8rem;
      font-weight: 400;
      color: var(--muted);
    }

    .disc {
      margin-top: 1rem;
    }

    .disc-title {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
      margin-bottom: 0.4rem;
    }

    .track-rows {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .track-row {
      display: flex;
      gap: 1rem;
      padding: 0.4rem 0;
      border-bottom: 1px solid var(--border);
    }

    .track-num {
      flex-shrink: 0;
      width: 2rem;
      text-align: right;
      color: var(--muted);
      font-variant-numeric: tabular-nums;
    }

    .track-title {
      min-width: 0;
    }
  </style>
</Base>