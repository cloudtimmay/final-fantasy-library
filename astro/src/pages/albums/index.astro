---
import Base from '../../layouts/Base.astro'
import { sanity, SHARED_FIELDS } from '../../lib/sanity'

const albums = await sanity.fetch(`
  *[_type == "album" && !(_id in path("drafts.**"))] | order(artist asc, title asc) {
    _id, title, artist, composer, year, genre, format, series, catalogNumber, vgmdbId, vgmdbUrl, externalImageUrl,
    "trackCount": count(tracklist),
    "discCount": count(array::unique(tracklist[].disc)),
    ${SHARED_FIELDS}
  }
`)

const seriesList = [...new Set(albums.map((a: any) => a.series).filter(Boolean))].sort()

const now = Date.now()
function isNew(acquiredDate: string | undefined): boolean {
  if (!acquiredDate) return false
  const d = new Date(acquiredDate).getTime()
  if (isNaN(d)) return false
  const days = (now - d) / (1000 * 60 * 60 * 24)
  return days >= 0 && days <= 30
}
---
<Base title="Albums">
  <div class="page-header">
    <h1>Albums</h1>
    <span class="count">{albums.length} items</span>
  </div>

  <div class="vgmdb-lookup">
    <input id="vgmdb-search" type="search" placeholder="Slå opp album på VGMdb..." />
    <button id="vgmdb-go">Søk VGMdb ↗</button>
  </div>

  <div class="album-tools">
    <input id="album-search" type="search" placeholder="Search albums, artist, composer..." />
    <select id="album-sort">
      <option value="title">Sort by name</option>
      <option value="year">Sort by year</option>
      <option value="catalog">Sort by catalog number</option>
      <option value="acquired">Sort by date acquired</option>
    </select>
    <select id="album-status">
      <option value="">All statuses</option>
      <option value="owned">Owned</option>
      <option value="wishlist">Wishlist</option>
      <option value="sold">Sold</option>
      <option value="lent">Lent</option>
    </select>
    <select id="album-series">
      <option value="">All series</option>
      {seriesList.map((s: any) => <option value={s}>{s}</option>)}
    </select>
  </div>

  <div class="album-list">
    {albums.map((a: any) => (
      <div class="album-row-wrap" data-wishlist={a.status === 'wishlist' ? 'yes' : 'no'}>
        <a class="album-row" href={`/albums/${a._id}`} data-title={a.title?.toLowerCase() || ''} data-artist={a.artist?.toLowerCase() || ''} data-composer={a.composer?.toLowerCase() || ''} data-catalog={a.catalogNumber?.toLowerCase() || ''} data-year={a.year || ''} data-series={a.series || ''} data-status={a.status || ''} data-acquired={a.acquiredDate || ''}>
          {a.externalImageUrl
            ? <img class="album-thumb" src={a.externalImageUrl} alt={a.title} loading="lazy" />
            : <div class="album-thumb placeholder">🎵</div>
          }
          <div class="album-info">
            <div class="card-title">{a.title}</div>
            <div class="card-sub">{a.composer || a.artist}</div>
            <div class="card-meta">
              {isNew(a.acquiredDate) && <span class="tag new-tag">NY</span>}
              {a.status === 'wishlist' && <span class="tag wishlist-tag">Wishlist</span>}
              {a.catalogNumber && <span class="tag">{a.catalogNumber}</span>}
              {a.year && <span class="tag">{a.year}</span>}
              {a.format && <span class="tag">{a.format}</span>}
              {a.trackCount > 0 && <span class="tag">{a.discCount > 1 ? `${a.discCount} disker · ` : ''}{a.trackCount} spor</span>}
            </div>
          </div>
        </a>
        {a.status === 'wishlist' && (
          <button class="got-btn" data-id={a._id}>✓ Got it</button>
        )}
      </div>
    ))}
  </div>

  <style>
    .vgmdb-lookup { display: flex; gap: 0.75rem; margin: 1rem 0 0.5rem; flex-wrap: wrap; }
    .vgmdb-lookup input { flex: 1; min-width: 200px; background: var(--surface); color: var(--text); border: 1px solid var(--border); padding: 0.6rem 0.75rem; border-radius: 6px; }
    .vgmdb-lookup button { background: var(--surface); color: var(--text); border: 1px solid var(--accent); padding: 0.6rem 1rem; border-radius: 6px; cursor: pointer; white-space: nowrap; }
    .album-list { display: flex; flex-direction: column; border-top: 1px solid var(--border); }
    .album-row-wrap { display: flex; align-items: center; gap: 0.75rem; border-bottom: 1px solid var(--border); }
    .album-row { display: flex; gap: 1rem; padding: 0.75rem 0; text-decoration: none; color: inherit; align-items: center; flex: 1; min-width: 0; }
    .album-row:hover { background: rgba(255,255,255,0.03); }
    .album-thumb { width: 56px; height: 56px; object-fit: cover; background: var(--border); flex-shrink: 0; }
    .album-thumb.placeholder { display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
    .album-info { min-width: 0; }
    .wishlist-tag { background: var(--wishlist); color: var(--bg); }
    .owned-tag { background: #2ecc71; color: #06281a; font-weight: 700; }
    .got-btn { flex-shrink: 0; background: #2ecc71; color: #06281a; border: none; padding: 0.45rem 0.7rem; border-radius: 6px; font-size: 0.8rem; font-weight: 600; cursor: pointer; white-space: nowrap; }
    .got-btn:disabled { opacity: 0.6; cursor: default; }
    .album-tools { display: flex; gap: 0.75rem; margin: 0.5rem 0 1.5rem; flex-wrap: wrap; }
    .album-tools input, .album-tools select { background: var(--surface); color: var(--text); border: 1px solid var(--border); padding: 0.6rem 0.75rem; border-radius: 6px; }
    .album-row .card-meta .new-tag { background: #2ecc71 !important; color: #06281a !important; font-weight: 700; }
  </style>

  <script>
    import { initGotIt } from '../../scripts/got-it.js'

    const vgmdbInput = document.querySelector('#vgmdb-search')
    const vgmdbBtn = document.querySelector('#vgmdb-go')
    function vgmdbSearch() {
      const q = vgmdbInput.value.trim()
      if (!q) return
      window.open('https://vgmdb.net/search?q=' + encodeURIComponent(q), '_blank', 'noopener')
    }
    vgmdbBtn.addEventListener('click', vgmdbSearch)
    vgmdbInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') vgmdbSearch() })

    const searchInput = document.querySelector('#album-search')
    const sortSelect = document.querySelector('#album-sort')
    const statusSelect = document.querySelector('#album-status')
    const seriesSelect = document.querySelector('#album-series')
    const list = document.querySelector('.album-list')

    function updateAlbums() {
      const search = searchInput.value.toLowerCase()
      const sort = sortSelect.value
      const status = statusSelect.value
      const series = seriesSelect.value
      const rows = Array.from(document.querySelectorAll('.album-row-wrap'))

      rows.forEach((wrap) => {
        const row = wrap.querySelector('.album-row')
        const matchesSearch =
          row.dataset.title.includes(search) ||
          row.dataset.artist.includes(search) ||
          row.dataset.composer.includes(search) ||
          row.dataset.catalog.includes(search)
        const matchesStatus = !status || row.dataset.status === status
        const matchesSeries = !series || row.dataset.series === series
        wrap.style.display = matchesSearch && matchesStatus && matchesSeries ? '' : 'none'
      })

      rows
        .sort((a, b) => {
          const ra = a.querySelector('.album-row'), rb = b.querySelector('.album-row')
          if (sort === 'year') return (Number(rb.dataset.year) || 0) - (Number(ra.dataset.year) || 0)
          if (sort === 'catalog') return ra.dataset.catalog.localeCompare(rb.dataset.catalog)
          if (sort === 'acquired') {
            const ad = ra.dataset.acquired || '', bd = rb.dataset.acquired || ''
            if (!ad && !bd) return 0
            if (!ad) return 1
            if (!bd) return -1
            return bd.localeCompare(ad)
          }
          return ra.dataset.title.localeCompare(rb.dataset.title)
        })
        .forEach((wrap) => list.appendChild(wrap))
    }

    searchInput.addEventListener('input', updateAlbums)
    sortSelect.addEventListener('change', updateAlbums)
    statusSelect.addEventListener('change', updateAlbums)
    seriesSelect.addEventListener('change', updateAlbums)

    initGotIt()
  </script>
</Base>