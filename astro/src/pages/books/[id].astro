---
import Base from '../../layouts/Base.astro'
import { sanity, SHARED_FIELDS, urlFor } from '../../lib/sanity'

const { id } = Astro.params
const b = await sanity.fetch(
  `*[_type == "book" && _id == $id][0] { title, author, year, publisher, isbn, pages, genre, language, readStatus, readDate, needsInfo, externalImageUrl, image, ${SHARED_FIELDS} }`,
  { id }
)
if (!b) return Astro.redirect('/books')
---
<Base title={b.title}>
  <div class="detail">
    <a href="/books" style="font-size:13px;color:var(--muted)">← Books</a>
    <br /><br />
    <h1>{b.title}</h1>
    <div class="detail-sub">{b.author}</div>

    {b.needsInfo && (
      <div class="needsinfo-banner">
        Denne boka mangler informasjon. ISBN: <span class="mono">{b.isbn}</span> — slå den opp og fyll inn i Studio.
      </div>
    )}

    {b.image
      ? <img class="detail-photo" src={urlFor(b.image).height(600).url()} alt={b.title} />
      : b.externalImageUrl
      ? <img class="detail-photo" src={b.externalImageUrl} alt={b.title} />
      : <div class="detail-photo-placeholder">📚</div>
    }

    <div class="upload-row">
      <label class="upload-btn">
        📷 Take photo
        <input id="img-camera" type="file" accept="image/*" capture="environment" hidden />
      </label>
      <label class="upload-btn">
        🖼️ Choose from gallery
        <input id="img-gallery" type="file" accept="image/*" hidden />
      </label>
      <span id="upload-msg" class="upload-msg" hidden></span>
    </div>

    <table class="meta-table">
      {b.year       && <tr><td>Year</td><td>{b.year}</td></tr>}
      {b.publisher  && <tr><td>Publisher</td><td>{b.publisher}</td></tr>}
      {b.genre      && <tr><td>Genre</td><td>{b.genre}</td></tr>}
      {b.language   && <tr><td>Language</td><td>{b.language}</td></tr>}
      {b.pages      && <tr><td>Pages</td><td>{b.pages}</td></tr>}
      {b.isbn       && <tr><td>ISBN</td><td class="mono">{b.isbn}</td></tr>}
      {b.readStatus && <tr><td>Read</td><td>{b.readStatus}</td></tr>}
      {b.readDate   && <tr><td>Finished</td><td>{b.readDate}</td></tr>}
      {b.status     && <tr><td>Ownership</td><td>{b.status}</td></tr>}
      {b.rating     && <tr><td>Rating</td><td class="rating">{b.rating} / 10</td></tr>}
      {b.acquiredDate && <tr><td>Acquired</td><td>{b.acquiredDate}</td></tr>}
    </table>

    {b.tags?.length > 0 && (
      <div style="margin-top:1rem;display:flex;gap:0.5rem;flex-wrap:wrap">
        {b.tags.map((t: string) => <span class="tag">{t}</span>)}
      </div>
    )}
    {b.notes && <div class="notes-block">{b.notes}</div>}
  </div>

  <script>
    const camera = document.querySelector('#img-camera')
    const gallery = document.querySelector('#img-gallery')
    const uploadMsg = document.querySelector('#upload-msg')
    const detailPhoto = document.querySelector('.detail-photo, .detail-photo-placeholder')

    async function handleUpload(fileInput) {
      const file = fileInput.files && fileInput.files[0]
      if (!file) return

      uploadMsg.hidden = false
      uploadMsg.style.color = 'var(--muted)'
      uploadMsg.textContent = 'Uploading…'

      const form = new FormData()
      form.append('file', file)
      form.append('docId', window.location.pathname.split('/').pop())
      form.append('field', 'image')

      try {
        const res = await fetch('/api/upload-image', { method: 'POST', body: form })
        const data = await res.json()
        if (!res.ok) {
          uploadMsg.style.color = '#e74c3c'
          uploadMsg.textContent = data.error || 'Upload failed.'
          return
        }
        uploadMsg.style.color = '#2ecc71'
        uploadMsg.textContent = 'Uploaded ✓'
        if (detailPhoto && data.url) {
          const fresh = data.url + '?t=' + Date.now()
          if (detailPhoto.tagName === 'IMG') {
            detailPhoto.src = fresh
          } else {
            const img = document.createElement('img')
            img.className = 'detail-photo'
            img.src = fresh
            img.alt = document.querySelector('h1')?.textContent || ''
            detailPhoto.replaceWith(img)
          }
        }
      } catch {
        uploadMsg.style.color = '#e74c3c'
        uploadMsg.textContent = 'Network error.'
      }
    }

    if (camera) camera.addEventListener('change', () => handleUpload(camera))
    if (gallery) gallery.addEventListener('change', () => handleUpload(gallery))
  </script>

  <style>
    .detail-photo { max-width: 280px; width: 100%; border-radius: 6px; margin: 1rem 0; display: block; }
    .detail-photo-placeholder {
      width: 200px; height: 280px; border-radius: 6px; margin: 1rem 0;
      background: var(--surface); border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center; font-size: 3rem;
    }
    .needsinfo-banner {
      background: var(--surface); border: 1px solid var(--accent);
      border-radius: 6px; padding: 0.75rem 1rem; margin: 1rem 0;
      font-size: 0.9rem; color: var(--text);
    }
    .upload-row { display: flex; align-items: center; gap: 0.5rem; margin: 1rem 0 1.5rem; flex-wrap: wrap; }
    .upload-btn { display: inline-block; background: var(--surface); color: var(--text); border: 1px solid var(--accent); padding: 0.55rem 0.9rem; border-radius: 8px; cursor: pointer; font-size: 0.9rem; }
    .upload-btn:hover { background: #241826; }
    .upload-msg { font-size: 0.85rem; width: 100%; }
    .mono { font-family: monospace; }
  </style>
</Base>