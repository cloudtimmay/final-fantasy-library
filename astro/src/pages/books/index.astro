---
import Base from '../../layouts/Base.astro'
import { sanity, SHARED_FIELDS, urlFor } from '../../lib/sanity'

const books = await sanity.fetch(`
  *[_type == "book" && !(_id in path("drafts.**"))] | order(author asc, title asc) {
    _id, title, author, year, genre, publisher, isbn, readStatus, needsInfo, externalImageUrl, image, ${SHARED_FIELDS}
  }
`)

const now = Date.now()
function isNew(acquiredDate: string | undefined): boolean {
  if (!acquiredDate) return false
  const d = new Date(acquiredDate).getTime()
  if (isNaN(d)) return false
  const days = (now - d) / (1000 * 60 * 60 * 24)
  return days >= 0 && days <= 30
}
---
<Base title="Books">
  <div class="page-header">
    <h1>Books</h1>
    <span class="count">{books.length} items</span>
  </div>

  <details class="lookup-box" id="lookup-box">
    <summary>Look up a book externally (ISBN or title)</summary>
    <div class="lookup-inner">
      <input id="book-lookup" type="search" placeholder="ISBN or title..." />
      <div class="source-buttons">
        <button data-src="openlibrary">Open Library</button>
        <button data-src="googlebooks">Google Books</button>
        <button data-src="bookfinder">BookFinder</button>
        <button data-src="abebooks">AbeBooks</button>
        <button data-src="worldcat">WorldCat</button>
      </div>
    </div>
  </details>

  <div class="book-tools">
    <input id="book-search" type="search" placeholder="Search my books..." />
    <select id="book-sort">
      <option value="title">Sort by title</option>
      <option value="acquired">Sort by date acquired</option>
    </select>
    <select id="book-status">
      <option value="">All read status</option>
      <option value="unread">Unread</option>
      <option value="reading">Reading</option>
      <option value="read">Read</option>
      <option value="dnf">DNF</option>
    </select>
    <select id="book-info-filter">
      <option value="">All books</option>
      <option value="needsinfo">Missing info</option>
    </select>
  </div>

  <div class="book-list">
    {books.map((b: any) => (
      <div class="book-row-wrap"
           data-wishlist={b.status === 'wishlist' ? 'yes' : 'no'}
           data-title={b.title?.toLowerCase() || ''}
           data-author={b.author?.toLowerCase() || ''}
           data-isbn={b.isbn || ''}
           data-readstatus={b.readStatus || ''}
           data-needsinfo={b.needsInfo ? 'yes' : 'no'}
           data-acquired={b.acquiredDate || ''}>
        <a class="book-row" href={`/books/${b._id}`}>
          {b.image
            ? <img class="book-thumb" src={urlFor(b.image).height(120).url()} alt={b.title} loading="lazy" />
            : b.externalImageUrl
            ? <img class="book-thumb" src={b.externalImageUrl} alt={b.title} loading="lazy" />
            : <div class="book-thumb placeholder">📚</div>
          }
          <div class="book-info">
            <div class="card-title">{b.title}</div>
            <div class="card-sub">{b.author}{b.year ? ` · ${b.year}` : ''}</div>
            <div class="card-meta">
              {isNew(b.acquiredDate) && <span class="tag new-tag">NEW</span>}
              {b.status === 'wishlist' && <span class="tag wishlist-tag">Wishlist</span>}
              {b.needsInfo && <span class="tag needsinfo-tag">Missing info</span>}
              {b.publisher && <span class="tag">{b.publisher}</span>}
              {b.readStatus && <span class="tag">{b.readStatus}</span>}
              {b.rating && <span class="rating">{b.rating}/10</span>}
            </div>
          </div>
        </a>
        {b.status === 'wishlist' ? (
          <button class="got-btn" data-id={b._id}>✓ Got it</button>
        ) : b.needsInfo && (
          <button class="lookup-btn" data-query={b.isbn || b.title}>🔍 Look up</button>
        )}
      </div>
    ))}
  </div>

  <style>
    .lookup-box { border: 1px solid var(--border); border-radius: 6px; margin-bottom: 1.5rem; background: var(--surface); }
    .lookup-box summary { cursor: pointer; padding: 0.75rem 1rem; font-size: 0.9rem; color: var(--muted); }
    .lookup-inner { padding: 0 1rem 1rem; }
    .lookup-inner input { width: 100%; background: var(--bg); color: var(--text); border: 1px solid var(--border); padding: 0.6rem 0.75rem; border-radius: 6px; margin-bottom: 0.75rem; }
    .source-buttons { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .source-buttons button { background: var(--bg); color: var(--text); border: 1px solid var(--border); padding: 0.5rem 0.85rem; border-radius: 6px; cursor: pointer; font-size: 0.85rem; }
    .source-buttons button:hover { border-color: var(--accent); }

    .book-tools { display: flex; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .book-tools input, .book-tools select { background: var(--surface); color: var(--text); border: 1px solid var(--border); padding: 0.6rem 0.75rem; border-radius: 6px; }
    .book-tools input { flex: 1; min-width: 200px; }

    .book-list { display: flex; flex-direction: column; border-top: 1px solid var(--border); }
    .book-row-wrap { display: flex; align-items: center; gap: 0.75rem; border-bottom: 1px solid var(--border); }
    .book-row { display: flex; gap: 1rem; padding: 0.75rem 0; text-decoration: none; color: inherit; align-items: center; flex: 1; min-width: 0; }
    .book-row:hover { background: rgba(255,255,255,0.03); }
    .book-thumb { width: 48px; height: 64px; object-fit: cover; background: var(--border); flex-shrink: 0; border-radius: 3px; }
    .book-thumb.placeholder { display: flex; align-items: center; justify-content: center; font-size: 1.4rem; }
    .book-info { min-width: 0; }
    .needsinfo-tag { background: var(--wishlist, #c0392b); color: var(--bg); }
    .wishlist-tag { background: var(--wishlist, #c0392b); color: var(--bg); }
    .owned-tag { background: #2ecc71; color: #06281a; font-weight: 700; }
    .lookup-btn { background: var(--surface); color: var(--text); border: 1px solid var(--accent); padding: 0.45rem 0.7rem; border-radius: 6px; cursor: pointer; font-size: 0.8rem; white-space: nowrap; flex-shrink: 0; }
    .got-btn { flex-shrink: 0; background: #2ecc71; color: #06281a; border: none; padding: 0.45rem 0.7rem; border-radius: 6px; font-size: 0.8rem; font-weight: 600; cursor: pointer; white-space: nowrap; }
    .got-btn:disabled { opacity: 0.6; cursor: default; }
    .book-row .card-meta .new-tag { background: #2ecc71 !important; color: #06281a !important; font-weight: 700; }
  </style>

  <script>
    import { initGotIt } from '../../scripts/got-it.js'

    const lookupBox = document.querySelector('#lookup-box')
    const lookupInput = document.querySelector('#book-lookup')
    function lval() { return lookupInput.value.trim() }
    function isIsbn(s) { return /^[0-9Xx-]{10,17}$/.test(s.replace(/\s/g, '')) }
    function cleanIsbn(s) { return s.replace(/[^0-9Xx]/g, '') }

    function openSource(src) {
      const q = lval()
      if (!q) return
      const enc = encodeURIComponent(q)
      const isbn = cleanIsbn(q)
      let url = ''
      switch (src) {
        case 'openlibrary': url = isIsbn(q) ? `https://openlibrary.org/isbn/${isbn}` : `https://openlibrary.org/search?q=${enc}`; break
        case 'googlebooks': url = `https://www.google.com/search?tbm=bks&q=${isIsbn(q) ? 'isbn:' + isbn : enc}`; break
        case 'bookfinder': url = isIsbn(q) ? `https://www.bookfinder.com/isbn/${isbn}/` : `https://www.bookfinder.com/search/?keywords=${enc}`; break
        case 'abebooks': url = isIsbn(q) ? `https://www.abebooks.com/servlet/SearchResults?isbn=${isbn}` : `https://www.abebooks.com/servlet/SearchResults?kn=${enc}`; break
        case 'worldcat': url = `https://search.worldcat.org/search?q=${enc}`; break
      }
      if (url) window.open(url, '_blank', 'noopener')
    }
    document.querySelectorAll('.source-buttons button').forEach((btn) => {
      btn.addEventListener('click', () => openSource(btn.dataset.src))
    })

    document.querySelectorAll('.lookup-btn').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault()
        lookupInput.value = btn.dataset.query
        lookupBox.open = true
        lookupBox.scrollIntoView({ behavior: 'smooth', block: 'start' })
        lookupInput.focus()
      })
    })

    const searchInput = document.querySelector('#book-search')
    const sortSelect = document.querySelector('#book-sort')
    const statusSelect = document.querySelector('#book-status')
    const infoFilter = document.querySelector('#book-info-filter')
    const list = document.querySelector('.book-list')

    function updateBooks() {
      const search = searchInput.value.toLowerCase()
      const sort = sortSelect.value
      const status = statusSelect.value
      const info = infoFilter.value
      const rows = Array.from(document.querySelectorAll('.book-row-wrap'))

      rows.forEach((row) => {
        const matchesSearch = row.dataset.title.includes(search) || row.dataset.author.includes(search) || row.dataset.isbn.includes(search)
        const matchesStatus = !status || row.dataset.readstatus === status
        const matchesInfo = !info || (info === 'needsinfo' && row.dataset.needsinfo === 'yes')
        row.style.display = matchesSearch && matchesStatus && matchesInfo ? '' : 'none'
      })

      rows
        .sort((a, b) => {
          if (sort === 'acquired') {
            const ad = a.dataset.acquired || '', bd = b.dataset.acquired || ''
            if (!ad && !bd) return 0
            if (!ad) return 1
            if (!bd) return -1
            return bd.localeCompare(ad)
          }
          return a.dataset.title.localeCompare(b.dataset.title)
        })
        .forEach((row) => list.appendChild(row))
    }

    searchInput.addEventListener('input', updateBooks)
    sortSelect.addEventListener('change', updateBooks)
    statusSelect.addEventListener('change', updateBooks)
    infoFilter.addEventListener('change', updateBooks)

    initGotIt()
  </script>
</Base>