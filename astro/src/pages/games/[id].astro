---
import Base from '../../layouts/Base.astro'
import { sanity, SHARED_FIELDS, urlFor } from '../../lib/sanity'

export async function getStaticPaths() {
  const games = await sanity.fetch(`
    *[_type == "game" && !(_id in path("drafts.**"))]{ _id }
  `)

  return games.map((game: any) => ({
    params: { id: game._id },
  }))
}

const { id } = Astro.params
const g = await sanity.fetch(
  `*[_type == "game" && _id == $id][0] { title, developer, publisher, year, platform, genre, completionStatus, playtimeHours, needsInfo, barcode, externalImageUrl, image, ${SHARED_FIELDS} }`,
  { id }
)
if (!g) return Astro.redirect('/games')
---
<Base title={g.title}>
  <div class="detail">
    <a href="/games" style="font-size:13px;color:var(--muted)">← Games</a>
    <br /><br />
    <h1>{g.title}</h1>
    <div class="detail-sub">{g.developer}</div>

    {g.needsInfo && (
      <div class="needsinfo-banner">
        Dette spillet mangler informasjon{g.barcode ? <> (EAN: <span class="mono">{g.barcode}</span>)</> : null}. Sjekk tittel og plattform, og fyll inn i Studio.
      </div>
    )}

    {g.image
      ? <img class="detail-photo" src={urlFor(g.image).height(600).url()} alt={g.title} />
      : g.externalImageUrl
      ? <img class="detail-photo" src={g.externalImageUrl} alt={g.title} />
      : <div class="detail-photo-placeholder">🎮</div>
    }

    <table class="meta-table">
      {g.year             && <tr><td>Year</td><td>{g.year}</td></tr>}
      {g.platform && <tr><td>Platform</td><td>{g.platform}</td></tr>}
      {g.genre            && <tr><td>Genre</td><td>{g.genre}</td></tr>}
      {g.publisher        && <tr><td>Publisher</td><td>{g.publisher}</td></tr>}
      {g.completionStatus && <tr><td>Progress</td><td>{g.completionStatus}</td></tr>}
      {g.playtimeHours    && <tr><td>Playtime</td><td>{g.playtimeHours}h</td></tr>}
      {g.barcode          && <tr><td>EAN</td><td class="mono">{g.barcode}</td></tr>}
      {g.status           && <tr><td>Status</td><td>{g.status}</td></tr>}
      {g.rating           && <tr><td>Rating</td><td class="rating">{g.rating} / 10</td></tr>}
      {g.acquiredDate     && <tr><td>Acquired</td><td>{g.acquiredDate}</td></tr>}
    </table>

    {g.tags?.length > 0 && (
      <div style="margin-top:1rem;display:flex;gap:0.5rem;flex-wrap:wrap">
        {g.tags.map((t: string) => <span class="tag">{t}</span>)}
      </div>
    )}
    {g.notes && <div class="notes-block">{g.notes}</div>}
  </div>

  <style>
    .detail-photo { max-width: 280px; width: 100%; border-radius: 6px; margin: 1rem 0; display: block; }
    .detail-photo-placeholder { width: 200px; height: 280px; border-radius: 6px; margin: 1rem 0; background: var(--surface); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 3rem; }
    .needsinfo-banner { background: var(--surface); border: 1px solid var(--accent); border-radius: 6px; padding: 0.75rem 1rem; margin: 1rem 0; font-size: 0.9rem; }
    .mono { font-family: monospace; }
  </style>
</Base>