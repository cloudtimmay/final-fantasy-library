---
import Base from '../../layouts/Base.astro'
import { sanity, SHARED_FIELDS } from '../../lib/sanity'

export async function getStaticPaths() {
  const games = await sanity.fetch(`
    *[_type == "game"]{ _id }
  `)

  return games.map((game: any) => ({
    params: { id: game._id },
  }))
}

const { id } = Astro.params
const g = await sanity.fetch(
  `*[_type == "game" && _id == $id][0] { title, developer, publisher, year, platform, genre, completionStatus, playtimeHours, ${SHARED_FIELDS} }`,
  { id }
)
if (!g) return Astro.redirect('/games')
---
<Base title={g.title}>
  <div class="detail">
    <a href="/games" style="font-size:13px;color:var(--muted)">← Games</a>
    <br /><br />
    <h1>{g.title}</h1>
    <div class="detail-sub">{g.developer}</div>

    {g.photoUrl && <img class="detail-photo" src={g.photoUrl} alt={g.title} />}

    <table class="meta-table">
      {g.year             && <tr><td>Year</td><td>{g.year}</td></tr>}
      {g.platform?.length && <tr><td>Platform</td><td>{g.platform.join(', ')}</td></tr>}
      {g.genre            && <tr><td>Genre</td><td>{g.genre}</td></tr>}
      {g.publisher        && <tr><td>Publisher</td><td>{g.publisher}</td></tr>}
      {g.completionStatus && <tr><td>Progress</td><td>{g.completionStatus}</td></tr>}
      {g.playtimeHours    && <tr><td>Playtime</td><td>{g.playtimeHours}h</td></tr>}
      {g.status           && <tr><td>Status</td><td>{g.status}</td></tr>}
      {g.rating           && <tr><td>Rating</td><td class="rating">{g.rating} / 10</td></tr>}
      {g.acquiredDate     && <tr><td>Acquired</td><td>{g.acquiredDate}</td></tr>}
    </table>

    {g.tags?.length > 0 && (
      <div style="margin-top:1rem;display:flex;gap:0.5rem;flex-wrap:wrap">
        {g.tags.map((t: string) => <span class="tag">{t}</span>)}
      </div>
    )}
    {g.notes && <div class="notes-block">{g.notes}</div>}
  </div>
</Base>
