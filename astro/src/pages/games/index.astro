---
import Base from '../../layouts/Base.astro'
import { sanity, SHARED_FIELDS, urlFor } from '../../lib/sanity'

const games = await sanity.fetch(`
  *[_type == "game" && !(_id in path("drafts.**"))] | order(title asc) {
    _id, title, developer, year, platform, genre, completionStatus, needsInfo, barcode, externalImageUrl, image, ${SHARED_FIELDS}
  }
`)

const platformList = [...new Set(games.map((g: any) => g.platform).filter(Boolean))].sort()

const now = Date.now()
function isNew(acquiredDate: string | undefined): boolean {
  if (!acquiredDate) return false
  const d = new Date(acquiredDate).getTime()
  if (isNaN(d)) return false
  const days = (now - d) / (1000 * 60 * 60 * 24)
  return days >= 0 && days <= 30
}
---
<Base title="Games">
  <div class="page-header">
    <h1>Games</h1>
    <span class="count">{games.length} items</span>
  </div>

  <details class="lookup-box" id="lookup-box">
    <summary>Slå opp et spill eksternt (tittel eller strekkode)</summary>
    <div class="lookup-inner">
      <input id="game-lookup" type="search" placeholder="Tittel eller strekkode..." />
      <div class="source-buttons">
        <button data-src="mobygames">MobyGames</button>
        <button data-src="igdb">IGDB</button>
        <button data-src="rawg">RAWG</button>
        <button data-src="google">Google</button>
      </div>
    </div>
  </details>

  <div class="game-tools">
    <input id="game-search" type="search" placeholder="Søk i mine spill..." />
    <select id="game-sort">
      <option value="title">Sorter på tittel</option>
      <option value="acquired">Sorter på kjøpsdato</option>
    </select>
    <select id="game-platform">
      <option value="">Alle plattformer</option>
      {platformList.map((p: any) => <option value={p}>{p}</option>)}
    </select>
    <select id="game-info-filter">
      <option value="">Alle spill</option>
      <option value="needsinfo">Mangler info</option>
    </select>
  </div>

  <div class="game-list">
    {games.map((g: any) => (
      <div class="game-row-wrap"
           data-title={g.title?.toLowerCase() || ''}
           data-developer={g.developer?.toLowerCase() || ''}
           data-platform={(g.platform || '').toLowerCase()}
           data-needsinfo={g.needsInfo ? 'yes' : 'no'}
           data-acquired={g.acquiredDate || ''}>
        <a class="game-row" href={`/games/${g._id}`}>
          {g.image
            ? <img class="game-thumb" src={urlFor(g.image).height(120).url()} alt={g.title} loading="lazy" />
            : g.externalImageUrl
            ? <img class="game-thumb" src={g.externalImageUrl} alt={g.title} loading="lazy" />
            : <div class="game-thumb placeholder">🎮</div>
          }
          <div class="game-info">
            <div class="card-title">{g.title}</div>
            <div class="card-sub">{g.developer}{g.year ? ` · ${g.year}` : ''}</div>
            <div class="card-meta">
              {isNew(g.acquiredDate) && <span class="tag new-tag">NY</span>}
              {g.needsInfo && <span class="tag needsinfo-tag">Mangler info</span>}
              {g.platform && <span class="tag">{g.platform}</span>}
              {g.completionStatus && <span class="tag">{g.completionStatus}</span>}
              {g.rating && <span class="rating">{g.rating}/10</span>}
            </div>
          </div>
        </a>
        {g.needsInfo && (
          <button class="lookup-btn" data-query={g.barcode || g.title}>🔍 Slå opp</button>
        )}
      </div>
    ))}
  </div>

  <style>
    .lookup-box { border: 1px solid var(--border); border-radius: 6px; margin-bottom: 1.5rem; background: var(--surface); }
    .lookup-box summary { cursor: pointer; padding: 0.75rem 1rem; font-size: 0.9rem; color: var(--muted); }
    .lookup-inner { padding: 0 1rem 1rem; }
    .lookup-inner input { width: 100%; background: var(--bg); color: var(--text); border: 1px solid var(--border); padding: 0.6rem 0.75rem; border-radius: 6px; margin-bottom: 0.75rem; }
    .source-buttons { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .source-buttons button { background: var(--bg); color: var(--text); border: 1px solid var(--border); padding: 0.5rem 0.85rem; border-radius: 6px; cursor: pointer; font-size: 0.85rem; }
    .source-buttons button:hover { border-color: var(--accent); }

    .game-tools { display: flex; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .game-tools input, .game-tools select { background: var(--surface); color: var(--text); border: 1px solid var(--border); padding: 0.6rem 0.75rem; border-radius: 6px; }
    .game-tools input { flex: 1; min-width: 200px; }

    .game-list { display: flex; flex-direction: column; border-top: 1px solid var(--border); }
    .game-row-wrap { display: flex; align-items: center; gap: 0.75rem; border-bottom: 1px solid var(--border); }
    .game-row { display: flex; gap: 1rem; padding: 0.75rem 0; text-decoration: none; color: inherit; align-items: center; flex: 1; min-width: 0; }
    .game-row:hover { background: rgba(255,255,255,0.03); }
    .game-thumb { width: 48px; height: 64px; object-fit: cover; background: var(--border); flex-shrink: 0; border-radius: 3px; }
    .game-thumb.placeholder { display: flex; align-items: center; justify-content: center; font-size: 1.4rem; }
    .game-info { min-width: 0; }
    .needsinfo-tag { background: var(--wishlist, #c0392b); color: var(--bg); }
    .lookup-btn { background: var(--surface); color: var(--text); border: 1px solid var(--accent); padding: 0.45rem 0.7rem; border-radius: 6px; cursor: pointer; font-size: 0.8rem; white-space: nowrap; flex-shrink: 0; }
    .game-row .card-meta .new-tag { background: #2ecc71 !important; color: #06281a !important; font-weight: 700; }
  </style>

  <script>
    const lookupBox = document.querySelector('#lookup-box')
    const lookupInput = document.querySelector('#game-lookup')
    function lval() { return lookupInput.value.trim() }

    function openSource(src) {
      const q = lval()
      if (!q) return
      const enc = encodeURIComponent(q)
      let url = ''
      switch (src) {
        case 'mobygames': url = `https://www.mobygames.com/search/?q=${enc}`; break
        case 'igdb': url = `https://www.igdb.com/search?type=1&q=${enc}`; break
        case 'rawg': url = `https://rawg.io/search?query=${enc}`; break
        case 'google': url = `https://www.google.com/search?q=${enc}+game`; break
      }
      if (url) window.open(url, '_blank', 'noopener')
    }
    document.querySelectorAll('.source-buttons button').forEach((btn) => {
      btn.addEventListener('click', () => openSource(btn.dataset.src))
    })

    document.querySelectorAll('.lookup-btn').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault()
        lookupInput.value = btn.dataset.query
        lookupBox.open = true
        lookupBox.scrollIntoView({ behavior: 'smooth', block: 'start' })
        lookupInput.focus()
      })
    })

    const searchInput = document.querySelector('#game-search')
    const sortSelect = document.querySelector('#game-sort')
    const platformSelect = document.querySelector('#game-platform')
    const infoFilter = document.querySelector('#game-info-filter')
    const list = document.querySelector('.game-list')

    function updateGames() {
      const search = searchInput.value.toLowerCase()
      const sort = sortSelect.value
      const platform = platformSelect.value.toLowerCase()
      const info = infoFilter.value
      const rows = Array.from(document.querySelectorAll('.game-row-wrap'))

      rows.forEach((row) => {
        const matchesSearch = row.dataset.title.includes(search) || row.dataset.developer.includes(search)
        const matchesPlatform = !platform || row.dataset.platform === platform
        const matchesInfo = !info || (info === 'needsinfo' && row.dataset.needsinfo === 'yes')
        row.style.display = matchesSearch && matchesPlatform && matchesInfo ? '' : 'none'
      })

      rows
        .sort((a, b) => {
          if (sort === 'acquired') {
            const ad = a.dataset.acquired || ''
            const bd = b.dataset.acquired || ''
            if (!ad && !bd) return 0
            if (!ad) return 1
            if (!bd) return -1
            return bd.localeCompare(ad)
          }
          return a.dataset.title.localeCompare(b.dataset.title)
        })
        .forEach((row) => list.appendChild(row))
    }

    searchInput.addEventListener('input', updateGames)
    sortSelect.addEventListener('change', updateGames)
    platformSelect.addEventListener('change', updateGames)
    infoFilter.addEventListener('change', updateGames)
  </script>
</Base>