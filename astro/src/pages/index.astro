---
import Base from '../layouts/Base.astro'
import { sanity, SHARED_FIELDS, urlFor } from '../lib/sanity'

const [albumCount, gameCount, figureCount, bookCount] = await Promise.all([
  sanity.fetch<number>(`count(*[_type == "album" && !(_id in path("drafts.**"))])`),
  sanity.fetch<number>(`count(*[_type == "game" && !(_id in path("drafts.**"))])`),
  sanity.fetch<number>(`count(*[_type == "figure" && !(_id in path("drafts.**"))])`),
  sanity.fetch<number>(`count(*[_type == "book" && !(_id in path("drafts.**"))])`),
])

const recentlyAdded = await sanity.fetch(`
  *[_type in ["album","game","figure","book"] && !(_id in path("drafts.**"))] | order(_createdAt desc, _id) [0..7] {
    _id, _type, title, externalImageUrl, catalogNumber,
    "sub": select(
      _type == "album" => artist,
      _type == "game"  => platform[0],
      _type == "figure"=> series,
      _type == "book"  => author
    ),
    status, rating, image
  }
`)
---
<Base title="Dashboard">
  <div class="page-header">
    <h1>My Collection</h1>
  </div>

  <div class="stats-grid">
    <a href="/albums" class="stat-card">
      <div class="num">{albumCount}</div>
      <div class="label">🎵 Albums</div>
    </a>
    <a href="/games" class="stat-card">
      <div class="num">{gameCount}</div>
      <div class="label">🎮 Games</div>
    </a>
    <a href="/figures" class="stat-card">
      <div class="num">{figureCount}</div>
      <div class="label">🗿 Figures</div>
    </a>
    <a href="/books" class="stat-card">
      <div class="num">{bookCount}</div>
      <div class="label">📚 Books</div>
    </a>
    <div class="stat-card">
      <div class="num">{albumCount + gameCount + figureCount + bookCount}</div>
      <div class="label">Total items</div>
    </div>
  </div>

  <div class="page-header">
    <h2 style="font-size:1rem;font-weight:600">Recently added</h2>
  </div>

  <div class="recent-list">
    {recentlyAdded.map((item: any) => (
      <a class="recent-row" href={`/${item._type}s/${item._id}`}>
        {item.externalImageUrl ? (
          <img class="recent-thumb" src={item.externalImageUrl} alt={item.title} loading="lazy" />
        ) : item.image ? (
          <img class="recent-thumb" src={urlFor(item.image).height(80).url()} alt={item.title} loading="lazy" />
        ) : (
          <div class="recent-thumb placeholder">
            {item._type === 'album' && '🎵'}
            {item._type === 'game' && '🎮'}
            {item._type === 'figure' && '🗿'}
            {item._type === 'book' && '📚'}
          </div>
        )}

        <div class="recent-info">
          <div class="card-title">{item.title}</div>
          {item.sub && <div class="card-sub">{item.sub}</div>}
          <div class="card-meta">
            {item.catalogNumber && <span class="tag">{item.catalogNumber}</span>}
            {item.rating && <span class="rating">{item.rating}/10</span>}
            {item.status && <span class={`status-dot ${item.status}`}></span>}
          </div>
        </div>
      </a>
    ))}
  </div>

  <style>
    .recent-list {
      display: flex;
      flex-direction: column;
      border-top: 1px solid var(--border);
    }

    .recent-row {
      display: flex;
      gap: 1rem;
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--border);
      text-decoration: none;
      color: inherit;
      align-items: center;
    }

    .recent-row:hover {
      background: rgba(255,255,255,0.03);
    }

    .recent-thumb {
      width: 56px;
      height: 56px;
      object-fit: cover;
      background: var(--border);
      flex-shrink: 0;
    }

    .recent-thumb.placeholder {
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
    }

    .recent-info {
      min-width: 0;
    }
  </style>
</Base>