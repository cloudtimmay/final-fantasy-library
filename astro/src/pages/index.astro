---
import Base from '../layouts/Base.astro'
import { sanity, SHARED_FIELDS, urlFor } from '../lib/sanity'

const [albumCount, gameCount, merchCount, bookCount] = await Promise.all([
  sanity.fetch<number>(`count(*[_type == "album" && status != "wishlist" && !(_id in path("drafts.**"))])`),
  sanity.fetch<number>(`count(*[_type == "game" && status != "wishlist" && !(_id in path("drafts.**"))])`),
  sanity.fetch<number>(`count(*[_type == "merch" && status != "wishlist" && !(_id in path("drafts.**"))])`),
  sanity.fetch<number>(`count(*[_type == "book" && status != "wishlist" && !(_id in path("drafts.**"))])`),
])

const recentlyAdded = await sanity.fetch(`
  *[_type in ["album","game","merch","book"] && !(_id in path("drafts.**"))]
    | order(coalesce(acquiredDate, _createdAt) desc, _id) [0..19] {
    _id, _type, title, externalImageUrl, catalogNumber, acquiredDate,
    "sub": select(
      _type == "album" => artist,
      _type == "game"  => platform,
      _type == "merch"=> series,
      _type == "book"  => author
    ),
    status, rating, image
  }
`)

// "NY" hvis kjøpt siste 30 dager
const now = Date.now()
function isNew(acquiredDate: string | undefined): boolean {
  if (!acquiredDate) return false
  const d = new Date(acquiredDate).getTime()
  if (isNaN(d)) return false
  const days = (now - d) / (1000 * 60 * 60 * 24)
  return days >= 0 && days <= 30
}
---
<Base title="Dashboard">
  <div class="page-header">
    <h1>My Collection</h1>
  </div>

  <div class="stats-grid">
    <a href="/albums" class="stat-card">
      <div class="num">{albumCount}</div>
      <div class="label">🎵 Albums</div>
    </a>
    <a href="/games" class="stat-card">
      <div class="num">{gameCount}</div>
      <div class="label">🎮 Games</div>
    </a>
    <a href="/merchandise" class="stat-card">
      <div class="num">{merchCount}</div>
      <div class="label">🗿 merchandise</div>
    </a>
    <a href="/books" class="stat-card">
      <div class="num">{bookCount}</div>
      <div class="label">📚 Books</div>
    </a>
    <div class="stat-card">
      <div class="num">{albumCount + gameCount + merchCount + bookCount}</div>
      <div class="label">Total items</div>
    </div>
  </div>

  <div class="page-header">
    <h2 style="font-size:1rem;font-weight:600">Recently added</h2>
  </div>

  <div class="recent-list">
    {recentlyAdded.map((item: any) => (
      <a class="recent-row" href={`/${item._type}s/${item._id}`}>
        {item.externalImageUrl ? (
          <img class="recent-thumb" src={item.externalImageUrl} alt={item.title} loading="lazy" />
        ) : item.image ? (
          <img class="recent-thumb" src={urlFor(item.image).height(80).url()} alt={item.title} loading="lazy" />
        ) : (
          <div class="recent-thumb placeholder">
            {item._type === 'album' && '🎵'}
            {item._type === 'game' && '🎮'}
            {item._type === 'merch' && '🗿'}
            {item._type === 'book' && '📚'}
          </div>
        )}

        <div class="recent-info">
          <div class="card-title">{item.title}</div>
          {item.sub && <div class="card-sub">{Array.isArray(item.sub) ? item.sub.join(', ') : item.sub}</div>}
          <div class="card-meta">
            {isNew(item.acquiredDate) && <span class="tag new-tag">NY</span>}
            {item.acquiredDate && <span class="tag">Kjøpt {item.acquiredDate}</span>}
            {item.catalogNumber && <span class="tag">{item.catalogNumber}</span>}
            {item.rating && <span class="rating">{item.rating}/10</span>}
            {item.status && <span class={`status-dot ${item.status}`}></span>}
          </div>
        </div>
      </a>
    ))}
  </div>

  <style>
    .recent-list {
      display: flex;
      flex-direction: column;
      border-top: 1px solid var(--border);
    }

    .recent-row {
      display: flex;
      gap: 1rem;
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--border);
      text-decoration: none;
      color: inherit;
      align-items: center;
    }

    .recent-row:hover {
      background: rgba(255,255,255,0.03);
    }

    .recent-thumb {
      width: 56px;
      height: 56px;
      object-fit: cover;
      background: var(--border);
      flex-shrink: 0;
    }

    .recent-thumb.placeholder {
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
    }

    .recent-info {
      min-width: 0;
    }

    .recent-row .card-meta .new-tag {
      background: #2ecc71 !important;
      color: #06281a !important;
      font-weight: 700;
    }
  </style>
</Base>