---
import Base from '../../layouts/Base.astro'
import { sanity, SHARED_FIELDS, urlFor } from '../../lib/sanity'

export async function getStaticPaths() {
  const merchandise = await sanity.fetch(`
    *[_type == "merch" && !(_id in path("drafts.**"))]{ _id }
  `)

  return merchandise.map((merch: any) => ({
    params: { id: merch._id },
  }))
}

const { id } = Astro.params
const f = await sanity.fetch(
  `*[_type == "merch" && _id == $id][0] { title, series, manufacturer, year, scale, condition, location, needsInfo, externalImageUrl, ${SHARED_FIELDS} }`,
  { id }
)
if (!f) return Astro.redirect('/merchandise')
---
<Base title={f.title}>
  <div class="detail">
    <a href="/merchandise" style="font-size:13px;color:var(--muted)">← merchandise</a>
    <br /><br />
    <h1>{f.title}</h1>
    <div class="detail-sub">{f.series}</div>

    {f.needsInfo && (
      <div class="needsinfo-banner">
        This merch is missing information. Check the details and fill them in via Studio.
      </div>
    )}

    {f.image
      ? <img class="detail-photo" src={urlFor(f.image).width(900).url()} alt={f.title} />
      : f.externalImageUrl
      ? <img class="detail-photo" src={f.externalImageUrl} alt={f.title} />
      : <div class="detail-photo-placeholder">🗿</div>
    }

    <table class="meta-table">
      {f.manufacturer && <tr><td>Manufacturer</td><td>{f.manufacturer}</td></tr>}
      {f.year         && <tr><td>Year</td><td>{f.year}</td></tr>}
      {f.scale        && <tr><td>Scale</td><td>{f.scale}</td></tr>}
      {f.condition    && <tr><td>Condition</td><td>{f.condition}</td></tr>}
      {f.location     && <tr><td>Location</td><td>{f.location}</td></tr>}
      {f.status       && <tr><td>Status</td><td>{f.status}</td></tr>}
      {f.rating       && <tr><td>Rating</td><td class="rating">{f.rating} / 10</td></tr>}
      {f.acquiredDate && <tr><td>Acquired</td><td>{f.acquiredDate}</td></tr>}
      {f.purchasePrice && <tr><td>Paid</td><td>{f.purchasePrice} NOK</td></tr>}
      {f.purchasePriceYen && <tr><td>Paid (JPY)</td><td>¥{f.purchasePriceYen}</td></tr>}
    </table>

    {f.tags?.length > 0 && (
      <div style="margin-top:1rem;display:flex;gap:0.5rem;flex-wrap:wrap">
        {f.tags.map((t: string) => <span class="tag">{t}</span>)}
      </div>
    )}
    {f.notes && <div class="notes-block">{f.notes}</div>}
  </div>

  <style>
    .detail-photo { max-width: 280px; width: 100%; border-radius: 6px; margin: 1rem 0; display: block; }
    .detail-photo-placeholder { width: 200px; height: 280px; border-radius: 6px; margin: 1rem 0; background: var(--surface); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 3rem; }
    .needsinfo-banner { background: var(--surface); border: 1px solid var(--accent); border-radius: 6px; padding: 0.75rem 1rem; margin: 1rem 0; font-size: 0.9rem; }
  </style>
</Base>