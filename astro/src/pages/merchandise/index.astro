---
import Base from '../../layouts/Base.astro'
import { sanity, SHARED_FIELDS, urlFor } from '../../lib/sanity'

const merchandise = await sanity.fetch(`
  *[_type == "figure" && !(_id in path("drafts.**"))] | order(series asc, title asc) {
    _id, title, category, series, manufacturer, year, scale, condition, needsInfo, externalImageUrl, image, ${SHARED_FIELDS}
  }
`)

const seriesList = [...new Set(merchandise.map((f: any) => f.series).filter(Boolean))].sort()

const CATEGORY_LABELS: Record<string, string> = {
  figure: 'Figure',
  plushie: 'Plushie',
  wearable: 'Wearable',
  other: 'Other',
}

const now = Date.now()
function isNew(acquiredDate: string | undefined): boolean {
  if (!acquiredDate) return false
  const d = new Date(acquiredDate).getTime()
  if (isNaN(d)) return false
  const days = (now - d) / (1000 * 60 * 60 * 24)
  return days >= 0 && days <= 30
}
---
<Base title="Merchandise">
  <div class="hud-section-head">
    <span class="hud-slashes">//</span> MERCHANDISE
    <span class="hud-count" id="merch-count">{merchandise.length} ENTRIES</span>
  </div>

  <details class="lookup-box" id="lookup-box">
    <summary>Look up merchandise externally (name)</summary>
    <div class="lookup-inner">
      <input id="merch-lookup" type="search" placeholder="name..." />
      <div class="source-buttons">
        <button data-src="mfc">MyFigureCollection</button>
        <button data-src="google">Google</button>
        <button data-src="googleimg">Google Images</button>
      </div>
    </div>
  </details>

  <div class="merch-tools">
    <input id="merch-search" type="search" placeholder="Search my merchandise..." />
    <select id="merch-sort">
      <option value="title">Sort by name</option>
      <option value="acquired">Sort by date acquired</option>
    </select>
    <select id="merch-category">
      <option value="">All categories</option>
      <option value="figure">Figures</option>
      <option value="plushie">Plushies</option>
      <option value="wearable">Wearables</option>
      <option value="other">Other</option>
    </select>
    <select id="merch-series">
      <option value="">All series</option>
      {seriesList.map((s: any) => <option value={s}>{s}</option>)}
    </select>
    <select id="merch-info-filter">
      <option value="">All merchandise</option>
      <option value="needsinfo">Missing info</option>
    </select>
  </div>

  <div class="merch-list">
    {merchandise.map((f: any) => (
      <div class="merch-row-wrap"
           data-wishlist={f.status === 'wishlist' ? 'yes' : 'no'}
           data-title={f.title?.toLowerCase() || ''}
           data-series={f.series || ''}
           data-category={f.category || ''}
           data-needsinfo={f.needsInfo ? 'yes' : 'no'}
           data-acquired={f.acquiredDate || ''}>
        <span class="hud-corner tl"></span><span class="hud-corner tr"></span>
        <span class="hud-corner bl"></span><span class="hud-corner br"></span>
        <a class="merch-row" href={`/merchandise/${f._id}`}>
          {f.image
            ? <img class="merch-thumb" src={urlFor(f.image).height(120).url()} alt={f.title} loading="lazy" />
            : f.externalImageUrl
            ? <img class="merch-thumb" src={f.externalImageUrl} alt={f.title} loading="lazy" />
            : <div class="merch-thumb placeholder">🧸</div>
          }
          <div class="merch-info">
            <div class="card-title">{f.title}</div>
            <div class="card-sub">{f.series}{f.manufacturer ? ` · ${f.manufacturer}` : ''}</div>
            <div class="card-meta">
              {isNew(f.acquiredDate) && <span class="tag new-tag">NEW</span>}
              {f.status === 'wishlist' && <span class="tag wishlist-tag">WISHLIST</span>}
              {f.category && <span class="tag cat-tag">{CATEGORY_LABELS[f.category] || f.category}</span>}
              {f.needsInfo && <span class="tag needsinfo-tag">MISSING INFO</span>}
              {f.scale && <span class="tag">{f.scale}</span>}
              {f.year && <span class="tag">{f.year}</span>}
              {f.rating && <span class="rating">{f.rating}/10</span>}
            </div>
          </div>
        </a>
        {f.status === 'wishlist' ? (
          <button class="got-btn" data-id={f._id}>✓ Got it</button>
        ) : f.needsInfo && (
          <button class="lookup-btn" data-query={f.title}>🔍 Look up</button>
        )}
      </div>
    ))}
  </div>

  <style>
    /* HUD section head (matches dashboard) */
    .hud-section-head {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 1.1rem;
      letter-spacing: 0.1em;
      color: var(--text);
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid rgba(176,30,52,0.3);
      display: flex;
      align-items: baseline;
      gap: 1rem;
      text-shadow: 0 0 10px rgba(176,30,52,0.4);
    }
    .hud-slashes { color: var(--accent-2); }
    .hud-count {
      margin-left: auto;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.72rem;
      color: var(--muted);
      letter-spacing: 0.08em;
      text-shadow: none;
    }

    .lookup-box { border: 1px solid rgba(176,30,52,0.25); border-radius: 6px; margin-bottom: 1.5rem; background: rgba(26,12,18,0.4); }
    .lookup-box summary { cursor: pointer; padding: 0.75rem 1rem; font-size: 0.9rem; color: var(--muted); font-family: 'IBM Plex Mono', monospace; letter-spacing: 0.04em; }
    .lookup-inner { padding: 0 1rem 1rem; }
    .lookup-inner input { width: 100%; background: var(--bg); color: var(--text); border: 1px solid var(--border); padding: 0.6rem 0.75rem; border-radius: 6px; margin-bottom: 0.75rem; }
    .lookup-inner input:focus { outline: none; border-color: var(--accent); }
    .source-buttons { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .source-buttons button { background: var(--bg); color: var(--text); border: 1px solid var(--border); padding: 0.5rem 0.85rem; border-radius: 6px; cursor: pointer; font-size: 0.85rem; }
    .source-buttons button:hover { border-color: var(--accent); box-shadow: 0 0 10px rgba(244,162,76,0.3); }

    .merch-tools { display: flex; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .merch-tools input, .merch-tools select { background: var(--surface); color: var(--text); border: 1px solid var(--border); padding: 0.6rem 0.75rem; border-radius: 6px; }
    .merch-tools input { flex: 1; min-width: 200px; }
    .merch-tools input:focus, .merch-tools select:focus { outline: none; border-color: var(--accent); }

    /* HUD card rows */
    .merch-list { display: flex; flex-direction: column; gap: 0.5rem; }
    .merch-row-wrap {
      position: relative;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0 0.75rem;
      border: 1px solid rgba(176,30,52,0.18);
      border-radius: 4px;
      background: rgba(26,12,18,0.4);
      transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
    }
    .merch-row-wrap:hover {
      border-color: rgba(176,30,52,0.5);
      background: rgba(36,16,22,0.6);
      box-shadow: 0 0 14px rgba(120,16,26,0.25);
    }
    .merch-row { display: flex; gap: 1rem; padding: 0.75rem 0; text-decoration: none; color: inherit; align-items: center; flex: 1; min-width: 0; }
    .merch-thumb { width: 48px; height: 64px; object-fit: cover; background: var(--border); flex-shrink: 0; border-radius: 3px; }
    .merch-thumb.placeholder { display: flex; align-items: center; justify-content: center; font-size: 1.4rem; }
    .merch-info { min-width: 0; }
    .card-meta .tag { font-family: 'IBM Plex Mono', monospace; }
    .cat-tag { background: var(--accent); color: var(--bg); font-weight: 600; }
    .needsinfo-tag { background: var(--accent-2, #c0392b); color: #fff; }
    .wishlist-tag { background: var(--wishlist, #c0392b); color: var(--bg); }
    .owned-tag { background: #2ecc71; color: #06281a; font-weight: 700; }
    .lookup-btn { background: var(--surface); color: var(--text); border: 1px solid var(--accent); padding: 0.45rem 0.7rem; border-radius: 6px; cursor: pointer; font-size: 0.8rem; white-space: nowrap; flex-shrink: 0; }
    .got-btn { flex-shrink: 0; background: #2ecc71; color: #06281a; border: none; padding: 0.45rem 0.7rem; border-radius: 6px; font-size: 0.8rem; font-weight: 600; cursor: pointer; white-space: nowrap; }
    .got-btn:disabled { opacity: 0.6; cursor: default; }
    .merch-row .card-meta .new-tag { background: #2ecc71 !important; color: #06281a !important; font-weight: 700; }

    /* Corner brackets */
    .hud-corner {
      position: absolute;
      width: 8px;
      height: 8px;
      border-color: var(--accent-2);
      border-style: solid;
      border-width: 0;
      opacity: 0;
      transition: opacity 0.15s;
      pointer-events: none;
    }
    .merch-row-wrap:hover .hud-corner { opacity: 0.8; }
    .hud-corner.tl { top: -1px; left: -1px; border-top-width: 2px; border-left-width: 2px; }
    .hud-corner.tr { top: -1px; right: -1px; border-top-width: 2px; border-right-width: 2px; }
    .hud-corner.bl { bottom: -1px; left: -1px; border-bottom-width: 2px; border-left-width: 2px; }
    .hud-corner.br { bottom: -1px; right: -1px; border-bottom-width: 2px; border-right-width: 2px; }
  </style>

  <script>
    import { initGotIt } from '../../scripts/got-it.js'

    const lookupBox = document.querySelector('#lookup-box')
    const lookupInput = document.querySelector('#merch-lookup')
    function lval() { return lookupInput.value.trim() }

    function openSource(src) {
      const q = lval()
      if (!q) return
      const enc = encodeURIComponent(q)
      let url = ''
      switch (src) {
        case 'mfc': url = `https://myfigurecollection.net/?_tb=item&keywords=${enc}`; break
        case 'google': url = `https://www.google.com/search?q=${enc}+merchandise`; break
        case 'googleimg': url = `https://www.google.com/search?tbm=isch&q=${enc}+merchandise`; break
      }
      if (url) window.open(url, '_blank', 'noopener')
    }
    document.querySelectorAll('.source-buttons button').forEach((btn) => {
      btn.addEventListener('click', () => openSource(btn.dataset.src))
    })

    document.querySelectorAll('.lookup-btn').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault()
        lookupInput.value = btn.dataset.query
        lookupBox.open = true
        lookupBox.scrollIntoView({ behavior: 'smooth', block: 'start' })
        lookupInput.focus()
      })
    })

    const searchInput = document.querySelector('#merch-search')
    const sortSelect = document.querySelector('#merch-sort')
    const categorySelect = document.querySelector('#merch-category')
    const seriesSelect = document.querySelector('#merch-series')
    const infoFilter = document.querySelector('#merch-info-filter')
    const list = document.querySelector('.merch-list')
    const countEl = document.querySelector('#merch-count')

    function updateMerchandise() {
      const search = searchInput.value.toLowerCase()
      const sort = sortSelect.value
      const category = categorySelect.value
      const series = seriesSelect.value
      const info = infoFilter.value
      const rows = Array.from(document.querySelectorAll('.merch-row-wrap'))

      let visible = 0
      rows.forEach((row) => {
        const matchesSearch = row.dataset.title.includes(search)
        const matchesCategory = !category || row.dataset.category === category
        const matchesSeries = !series || row.dataset.series === series
        const matchesInfo = !info || (info === 'needsinfo' && row.dataset.needsinfo === 'yes')
        const show = matchesSearch && matchesCategory && matchesSeries && matchesInfo
        row.style.display = show ? '' : 'none'
        if (show) visible++
      })

      if (countEl) countEl.textContent = `${visible} ENTR${visible === 1 ? 'Y' : 'IES'}`

      rows
        .sort((a, b) => {
          if (sort === 'acquired') {
            const ad = a.dataset.acquired || '', bd = b.dataset.acquired || ''
            if (!ad && !bd) return 0
            if (!ad) return 1
            if (!bd) return -1
            return bd.localeCompare(ad)
          }
          return a.dataset.title.localeCompare(b.dataset.title)
        })
        .forEach((row) => list.appendChild(row))
    }

    searchInput.addEventListener('input', updateMerchandise)
    sortSelect.addEventListener('change', updateMerchandise)
    categorySelect.addEventListener('change', updateMerchandise)
    seriesSelect.addEventListener('change', updateMerchandise)
    infoFilter.addEventListener('change', updateMerchandise)

    updateMerchandise()
    initGotIt()
  </script>
</Base>