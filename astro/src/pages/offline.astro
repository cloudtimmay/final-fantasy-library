---
import Base from '../layouts/Base.astro'
import { sanity, SHARED_FIELDS } from '../lib/sanity'

const items = await sanity.fetch(`
  *[_type in ["album","game","book","figure"] && !(_id in path("drafts.**"))]
    | order(title asc) {
    _id, _type, title, status, barcode, series, acquiredDate,
    "sub": select(
      _type == "album" => coalesce(composer, artist),
      _type == "game"  => platform,
      _type == "book"  => author,
      _type == "figure"=> series
    ),
    "catalog": select(
      _type == "album" => catalogNumber,
      _type == "book"  => isbn,
      _type == "game"  => barcode,
      _type == "figure"=> barcode
    )
  }
`)

const generatedAt = new Date().toISOString()
---
<Base title="Offline">
  <div class="hud-section-head">
    <span class="hud-slashes">//</span> OFFLINE MODE
    <span class="hud-count" id="offline-count">{items.length} ENTRIES</span>
  </div>

  <p class="hint">
    Load your collection into this device while you have a connection. Then you can search
    and scan barcodes later without internet — for checking “do I already own this?” in a shop.
  </p>

  <div class="offline-status" id="status-box">
    <div class="status-line">
      <span class="status-label">Data copy:</span>
      <span id="cache-status">checking…</span>
    </div>
    <div class="status-line">
      <span class="status-label">Offline page:</span>
      <span id="sw-status">checking…</span>
    </div>
    <button id="refresh-btn" class="refresh-btn">↻ Update offline copy now</button>
  </div>

  <button id="scan-toggle" class="scan-cam-btn" type="button">📷 Scan barcode (offline)</button>
  <div id="scan-reader" class="scan-reader" hidden></div>
  <p id="scan-msg" class="scan-msg" hidden></p>

  <div class="offline-tools">
    <input id="offline-search" type="search" placeholder="Search offline (title, series, barcode, catalog…)" autocomplete="off" />
    <select id="offline-filter">
      <option value="">All statuses</option>
      <option value="owned">Owned</option>
      <option value="wishlist">Wishlist</option>
    </select>
    <select id="offline-type">
      <option value="">All types</option>
      <option value="album">Albums</option>
      <option value="game">Games</option>
      <option value="book">Books</option>
      <option value="figure">Merchandise</option>
    </select>
  </div>

  <div id="dup-banner" class="dup-banner" hidden></div>

  <div id="offline-results" class="offline-results"></div>
  <p id="offline-empty" class="offline-empty" hidden>No matches in your offline copy.</p>

  <script type="application/json" id="fresh-data" set:html={JSON.stringify({ items, generatedAt })}></script>

  <script is:inline src="/html5-qrcode.min.js"></script>

  <script>
    const CACHE_KEY = 'ff-offline-collection-v1'

    const cacheStatus = document.querySelector('#cache-status')
    const swStatus = document.querySelector('#sw-status')
    const refreshBtn = document.querySelector('#refresh-btn')
    const searchInput = document.querySelector('#offline-search')
    const filterSel = document.querySelector('#offline-filter')
    const typeSel = document.querySelector('#offline-type')
    const resultsBox = document.querySelector('#offline-results')
    const emptyMsg = document.querySelector('#offline-empty')
    const countEl = document.querySelector('#offline-count')
    const dupBanner = document.querySelector('#dup-banner')

    const scanToggle = document.querySelector('#scan-toggle')
    const scanReader = document.querySelector('#scan-reader')
    const scanMsg = document.querySelector('#scan-msg')

    const TYPE_LABEL = { album: 'ALBUM', game: 'GAME', book: 'BOOK', figure: 'MERCH' }
    const TYPE_PATH = { album: 'albums', game: 'games', book: 'books', figure: 'merchandise' }

    // --- Register the service worker so the page itself works offline ---
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js')
        .then((reg) => {
          swStatus.textContent = 'cached — will load offline'
          swStatus.style.color = '#2ecc71'
          // If there's an update waiting, note it.
          reg.addEventListener('updatefound', () => {
            swStatus.textContent = 'updating cache…'
            swStatus.style.color = 'var(--accent)'
          })
        })
        .catch(() => {
          swStatus.textContent = 'could not cache page — offline may not work'
          swStatus.style.color = '#e74c3c'
        })
    } else {
      swStatus.textContent = 'not supported in this browser'
      swStatus.style.color = '#e74c3c'
    }

    let freshData = null
    try {
      const raw = document.querySelector('#fresh-data')?.textContent
      if (raw) freshData = JSON.parse(raw)
    } catch {}

    function saveCache(data) {
      try { localStorage.setItem(CACHE_KEY, JSON.stringify(data)); return true } catch { return false }
    }
    function loadCache() {
      try { const raw = localStorage.getItem(CACHE_KEY); return raw ? JSON.parse(raw) : null } catch { return null }
    }
    function fmtDate(iso) {
      if (!iso) return 'unknown'
      const d = new Date(iso)
      if (isNaN(d.getTime())) return 'unknown'
      return d.toLocaleString()
    }

    let active = null

    if (freshData && freshData.items) {
      saveCache(freshData)
      active = freshData
      cacheStatus.textContent = `updated just now (${freshData.items.length} items)`
      cacheStatus.style.color = '#2ecc71'
    } else {
      const cached = loadCache()
      if (cached && cached.items) {
        active = cached
        cacheStatus.textContent = `from ${fmtDate(cached.generatedAt)} (${cached.items.length} items) — offline`
        cacheStatus.style.color = 'var(--accent)'
      } else {
        cacheStatus.textContent = 'none yet — connect and load this page once'
        cacheStatus.style.color = '#e74c3c'
      }
    }

    if (active && countEl) countEl.textContent = `${active.items.length} ENTRIES`

    refreshBtn.addEventListener('click', () => {
      cacheStatus.textContent = 'refreshing…'
      window.location.reload()
    })

    function escapeHtml(s) {
      return String(s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#039;')
    }

    function checkDuplicateLocal(code) {
      dupBanner.hidden = true
      dupBanner.innerHTML = ''
      if (!active || !active.items || !code) return
      const c = code.trim()
      const match = active.items.find((it) => (it.barcode || '') === c)
      if (match) {
        dupBanner.hidden = false
        const owned = match.status === 'owned'
        dupBanner.className = 'dup-banner ' + (owned ? 'owned' : 'other')
        dupBanner.innerHTML = owned
          ? `⚠️ <strong>Already owned:</strong> “${escapeHtml(match.title)}”.`
          : `ℹ️ <strong>In your list:</strong> “${escapeHtml(match.title)}” (${escapeHtml(match.status || match._type)}).`
      }
    }

    function render() {
      if (!active || !active.items) {
        resultsBox.innerHTML = ''
        emptyMsg.hidden = false
        emptyMsg.textContent = 'No offline copy yet. Connect to the internet and open this page once.'
        return
      }

      const q = searchInput.value.trim().toLowerCase()
      const status = filterSel.value
      const type = typeSel.value

      const matches = active.items.filter((it) => {
        const hay = [it.title, it.sub, it.series, it.barcode, it.catalog]
          .filter(Boolean).join(' ').toLowerCase()
        const matchesSearch = !q || hay.includes(q)
        const matchesStatus = !status || it.status === status
        const matchesType = !type || it._type === type
        return matchesSearch && matchesStatus && matchesType
      })

      if (matches.length === 0) {
        resultsBox.innerHTML = ''
        emptyMsg.hidden = false
        emptyMsg.textContent = 'No matches in your offline copy.'
        return
      }
      emptyMsg.hidden = true

      resultsBox.innerHTML = matches.slice(0, 300).map((it) => {
        const owned = it.status === 'owned'
        const wish = it.status === 'wishlist'
        const badge = owned
          ? '<span class="ob-badge owned">OWNED</span>'
          : wish
          ? '<span class="ob-badge wishlist">WISHLIST</span>'
          : ''
        const sub = [it.sub, it.catalog].filter(Boolean).join(' · ')
        const path = TYPE_PATH[it._type] || it._type + 's'
        return `
          <a class="ob-row" href="/${path}/${it._id}">
            <div class="ob-info">
              <div class="ob-title">${escapeHtml(it.title || 'Untitled')}</div>
              <div class="ob-sub">
                <span class="ob-type">${TYPE_LABEL[it._type] || it._type}</span>
                ${sub ? escapeHtml(sub) : ''}
              </div>
            </div>
            ${badge}
          </a>`
      }).join('')
    }

    searchInput.addEventListener('input', () => { dupBanner.hidden = true; render() })
    filterSel.addEventListener('change', render)
    typeSel.addEventListener('change', render)
    render()

    // --- Offline barcode scanning ---
    let scanner = null
    let running = false

    async function startScan() {
      if (typeof Html5Qrcode === 'undefined') {
        scanMsg.hidden = false
        scanMsg.textContent = 'Scanner not available. The local scanner file may be missing.'
        return
      }
      scanReader.hidden = false
      scanMsg.hidden = true
      scanner = new Html5Qrcode('scan-reader')
      try {
        await scanner.start(
          { facingMode: 'environment' },
          { fps: 10, qrbox: { width: 250, height: 150 } },
          (decodedText) => {
            const code = decodedText.replace(/[^0-9Xx]/g, '')
            searchInput.value = code
            stopScan()
            render()
            checkDuplicateLocal(code)
          },
          () => {}
        )
        running = true
        scanToggle.textContent = '✕ Close scanner'
      } catch (err) {
        scanMsg.hidden = false
        scanMsg.textContent = 'Could not access camera. Allow camera and try again.'
        scanReader.hidden = true
      }
    }

    async function stopScan() {
      if (scanner && running) {
        try { await scanner.stop() } catch (e) {}
        running = false
      }
      scanReader.hidden = true
      scanToggle.textContent = '📷 Scan barcode (offline)'
    }

    scanToggle.addEventListener('click', () => {
      if (running) stopScan()
      else startScan()
    })
  </script>

  <style>
    .hud-section-head {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 1.1rem;
      letter-spacing: 0.1em;
      color: var(--text);
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid rgba(176,30,52,0.3);
      display: flex;
      align-items: baseline;
      gap: 1rem;
      text-shadow: 0 0 10px rgba(176,30,52,0.4);
    }
    .hud-slashes { color: var(--accent-2); }
    .hud-count {
      margin-left: auto;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.72rem;
      color: var(--muted);
      letter-spacing: 0.08em;
      text-shadow: none;
    }

    .hint { font-size: 0.9rem; color: var(--muted); margin-bottom: 1.25rem; max-width: 560px; }

    .offline-status {
      background: rgba(26,12,18,0.5);
      border: 1px solid rgba(176,30,52,0.25);
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 1.25rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .status-line { display: flex; flex-direction: column; gap: 0.2rem; font-size: 0.9rem; }
    .status-label { font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; color: var(--muted); letter-spacing: 0.08em; }
    #cache-status, #sw-status { font-size: 0.9rem; }
    .refresh-btn {
      margin-left: auto;
      background: var(--surface); color: var(--text); border: 1px solid var(--accent);
      padding: 0.6rem 1rem; border-radius: 8px; cursor: pointer; font-size: 0.9rem; white-space: nowrap;
    }
    .refresh-btn:hover { box-shadow: 0 0 12px rgba(244,162,76,0.35); }

    .scan-cam-btn {
      width: 100%; background: var(--surface); color: var(--text); border: 1px solid var(--accent);
      padding: 0.8rem; border-radius: 8px; font-size: 1rem; cursor: pointer; margin-bottom: 1rem;
    }
    .scan-reader { width: 100%; max-width: 400px; margin: 0 auto 1rem; border-radius: 8px; overflow: hidden; }
    .scan-msg { font-size: 0.9rem; color: var(--muted); margin-bottom: 1rem; }

    .offline-tools { display: flex; gap: 0.75rem; margin-bottom: 1.25rem; flex-wrap: wrap; }
    .offline-tools input, .offline-tools select {
      background: var(--surface); color: var(--text); border: 1px solid var(--border);
      padding: 0.7rem 0.75rem; border-radius: 6px; font-size: 1rem;
    }
    .offline-tools input { flex: 1; min-width: 200px; }
    .offline-tools input:focus, .offline-tools select:focus { outline: none; border-color: var(--accent); }

    .dup-banner {
      padding: 0.85rem 1rem; border-radius: 8px; margin-bottom: 1.25rem; font-size: 0.95rem;
    }
    .dup-banner.owned { background: #4a0f1c; border: 1px solid #e74c3c; color: #ffd9d9; }
    .dup-banner.other { background: rgba(26,12,18,0.6); border: 1px solid var(--accent); color: var(--text); }
    .dup-banner strong { color: #fff; }

    .offline-results { display: flex; flex-direction: column; gap: 0.5rem; }
    .ob-row {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 0.75rem;
      border: 1px solid rgba(176,30,52,0.18);
      border-radius: 4px;
      background: rgba(26,12,18,0.4);
      text-decoration: none; color: inherit;
      transition: border-color 0.15s, background 0.15s;
    }
    .ob-row:hover { border-color: rgba(176,30,52,0.5); background: rgba(36,16,22,0.6); }
    .ob-info { flex: 1; min-width: 0; }
    .ob-title { font-weight: 600; font-size: 14px; }
    .ob-sub { display: flex; align-items: center; gap: 0.5rem; font-size: 12px; color: var(--muted); margin-top: 0.15rem; flex-wrap: wrap; }
    .ob-type {
      font-family: 'IBM Plex Mono', monospace; font-size: 9px; letter-spacing: 0.1em;
      color: var(--accent); border: 1px solid rgba(244,162,76,0.4);
      padding: 1px 5px; border-radius: 2px;
    }
    .ob-badge { flex-shrink: 0; font-size: 0.7rem; font-weight: 700; padding: 0.3rem 0.55rem; border-radius: 4px; font-family: 'IBM Plex Mono', monospace; }
    .ob-badge.owned { background: #2ecc71; color: #06281a; }
    .ob-badge.wishlist { background: var(--wishlist); color: #04263d; }
    .offline-empty { color: var(--muted); font-size: 0.9rem; padding: 1rem 0; }
  </style>
</Base>