---
import Base from '../layouts/Base.astro'
import { sanity, urlFor } from '../lib/sanity'

const STUDIO_URL = 'https://fflibrary.sanity.studio'

const q = (Astro.url.searchParams.get('q') || '').trim()

let results: any[] = []
if (q) {
  const term = `*${q}*`
  results = await sanity.fetch(
    `*[
      _type in ["album","game","book"] &&
      !(_id in path("drafts.**")) &&
      (
        title match $term ||
        catalogNumber match $term ||
        barcode match $term ||
        isbn match $term ||
        artist match $term ||
        composer match $term ||
        author match $term
      )
    ] | order(_type asc, title asc) {
      _id, _type, title, status, image, externalImageUrl,
      catalogNumber, barcode, isbn,
      "sub": select(
        _type == "album" => coalesce(composer, artist),
        _type == "game"  => platform,
        _type == "book"  => author
      )
    }`,
    { term }
  )
}
---
<Base title="Scan">
  <div class="scan-wrap">
    <h1>Scan</h1>
    <p class="hint">Search by title, catalog number, barcode or ISBN — or scan the barcode.</p>

    <form class="scan-form" method="get" action="/scan">
      <input
        id="scan-input"
        name="q"
        type="search"
        value={q}
        placeholder="Title, catalog no., barcode..."
        autocomplete="off"
      />
      <button type="submit">Search</button>
    </form>

    <button id="scan-toggle" class="scan-cam-btn" type="button">📷 Scan barcode</button>
    <div id="scan-reader" class="scan-reader" hidden></div>
    <p id="scan-msg" class="scan-msg" hidden></p>

    <button id="family-register" class="scan-fam-btn" type="button" data-studio={STUDIO_URL}>
      🛍️ Register as family purchase
    </button>
    <p id="family-msg" class="family-msg" hidden></p>

    {q && (
      <div class="scan-results">
        {results.length === 0 ? (
          <div class="no-match">
            <strong>Not in collection.</strong>
            <span>No matches for “{q}”. Look it up externally below.</span>
          </div>
        ) : (
          results.map((r: any) => (
            <a class="result-row" href={`/${r._type}s/${r._id}`}>
              {r.image
                ? <img class="result-thumb" src={urlFor(r.image).height(120).url()} alt={r.title} />
                : r.externalImageUrl
                ? <img class="result-thumb" src={r.externalImageUrl} alt={r.title} />
                : <div class="result-thumb placeholder">{r._type === 'album' ? '🎵' : r._type === 'game' ? '🎮' : '📚'}</div>
              }
              <div class="result-info">
                <div class="result-title">{r.title}</div>
                <div class="result-sub">
                  {Array.isArray(r.sub) ? r.sub.join(', ') : r.sub}
                  {r.catalogNumber ? ` · ${r.catalogNumber}` : ''}
                </div>
              </div>
              <div class="result-status">
                {r.status === 'owned' && <span class="badge owned">OWNED</span>}
                {r.status === 'wishlist' && <span class="badge wishlist">WISHLIST</span>}
                {r.status === 'sold' && <span class="badge sold">SOLD</span>}
                {r.status === 'lent' && <span class="badge lent">LENT OUT</span>}
                {!r.status && <span class="badge">{r._type}</span>}
              </div>
            </a>
          ))
        )}
      </div>
    )}

    {q && (
      <div class="ext-lookup">
        <h2>Look up “{q}” externally</h2>

        <div class="ext-group">
          <span class="ext-label">Albums</span>
          <a target="_blank" rel="noopener" href={`https://vgmdb.net/search?q=${encodeURIComponent(q)}`}>VGMdb ↗</a>
          <a target="_blank" rel="noopener" href={`https://www.google.com/search?q=${encodeURIComponent(q + ' soundtrack album')}`}>Google ↗</a>
        </div>

        <div class="ext-group">
          <span class="ext-label">Books</span>
          <a target="_blank" rel="noopener" href={`https://openlibrary.org/search?q=${encodeURIComponent(q)}`}>Open Library ↗</a>
          <a target="_blank" rel="noopener" href={`https://www.bookfinder.com/search/?keywords=${encodeURIComponent(q)}`}>BookFinder ↗</a>
          <a target="_blank" rel="noopener" href={`https://www.google.com/search?q=${encodeURIComponent(q + ' book')}`}>Google ↗</a>
        </div>

        <div class="ext-group">
          <span class="ext-label">Games</span>
          <a target="_blank" rel="noopener" href={`https://www.mobygames.com/search/?q=${encodeURIComponent(q)}`}>MobyGames ↗</a>
          <a target="_blank" rel="noopener" href={`https://www.igdb.com/search?type=1&q=${encodeURIComponent(q)}`}>IGDB ↗</a>
          <a target="_blank" rel="noopener" href={`https://www.google.com/search?q=${encodeURIComponent(q + ' game')}`}>Google ↗</a>
        </div>

        <div class="ext-group">
          <span class="ext-label">General</span>
          <a target="_blank" rel="noopener" href={`https://www.google.com/search?q=${encodeURIComponent(q)}`}>Google ↗</a>
          <a target="_blank" rel="noopener" href={`https://www.google.com/search?tbm=isch&q=${encodeURIComponent(q)}`}>Google Images ↗</a>
        </div>
      </div>
    )}
  </div>

  <style>
    .scan-wrap { max-width: 640px; }
    .hint { font-size: 0.9rem; color: var(--muted); margin: 0.25rem 0 1.25rem; }

    .scan-form { display: flex; gap: 0.5rem; margin-bottom: 0.75rem; }
    .scan-form input {
      flex: 1; min-width: 0; background: var(--surface); color: var(--text);
      border: 1px solid var(--border); padding: 0.9rem 1rem; border-radius: 8px; font-size: 1.1rem;
    }
    .scan-form button {
      background: var(--accent, #4a9); color: var(--bg); border: none;
      padding: 0.9rem 1.4rem; border-radius: 8px; font-size: 1.1rem; cursor: pointer; font-weight: 600;
    }

    .scan-cam-btn {
      width: 100%; background: var(--surface); color: var(--text); border: 1px solid var(--accent);
      padding: 0.8rem; border-radius: 8px; font-size: 1rem; cursor: pointer; margin-bottom: 1rem;
    }
    .scan-reader { width: 100%; max-width: 400px; margin: 0 auto 1rem; border-radius: 8px; overflow: hidden; }
    .scan-msg { font-size: 0.9rem; color: var(--muted); margin-bottom: 1rem; }

    .scan-fam-btn {
      width: 100%; background: var(--surface); color: var(--text); border: 1px solid var(--border);
      padding: 0.8rem; border-radius: 8px; font-size: 1rem; cursor: pointer; margin-bottom: 0.5rem;
    }
    .scan-fam-btn:hover { border-color: var(--accent); }
    .family-msg { font-size: 0.85rem; color: #2ecc71; margin-bottom: 1rem; }

    .scan-results { display: flex; flex-direction: column; border-top: 1px solid var(--border); margin-bottom: 1.5rem; }
    .result-row { display: flex; gap: 1rem; padding: 0.85rem 0; border-bottom: 1px solid var(--border); text-decoration: none; color: inherit; align-items: center; }
    .result-row:hover { background: rgba(255,255,255,0.03); }
    .result-thumb { width: 52px; height: 52px; object-fit: cover; background: var(--border); flex-shrink: 0; border-radius: 4px; }
    .result-thumb.placeholder { display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
    .result-info { flex: 1; min-width: 0; }
    .result-title { font-weight: 600; }
    .result-sub { font-size: 0.85rem; color: var(--muted); }
    .result-status { flex-shrink: 0; }
    .badge { display: inline-block; padding: 0.35rem 0.6rem; border-radius: 6px; font-size: 0.75rem; font-weight: 700; background: var(--border); color: var(--text); }
    .badge.owned { background: #2ecc71; color: #06281a; }
    .badge.wishlist { background: #3498db; color: #04263d; }
    .badge.sold { background: #e67e22; color: #2a1604; }
    .badge.lent { background: #9b59b6; color: #1f0d28; }

    .no-match { padding: 1.25rem 0; display: flex; flex-direction: column; gap: 0.35rem; }
    .no-match strong { font-size: 1.1rem; }
    .no-match span { color: var(--muted); font-size: 0.9rem; }

    .ext-lookup h2 { font-size: 1rem; margin-bottom: 0.75rem; }
    .ext-group { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.6rem; }
    .ext-label { font-size: 0.8rem; color: var(--muted); width: 60px; flex-shrink: 0; }
    .ext-group a {
      background: var(--surface); color: var(--text); border: 1px solid var(--border);
      padding: 0.5rem 0.85rem; border-radius: 6px; text-decoration: none; font-size: 0.85rem;
    }
    .ext-group a:hover { border-color: var(--accent); }
  </style>

  <script is:inline src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
  <script is:inline>
    (function () {
      const toggle = document.getElementById('scan-toggle')
      const reader = document.getElementById('scan-reader')
      const msg = document.getElementById('scan-msg')
      const input = document.getElementById('scan-input')
      let scanner = null
      let running = false

      function showMsg(text) {
        msg.hidden = false
        msg.textContent = text
      }

      async function startScan() {
        if (typeof Html5Qrcode === 'undefined') {
          showMsg('Scanner could not be loaded. Check your connection.')
          return
        }
        reader.hidden = false
        msg.hidden = true
        scanner = new Html5Qrcode('scan-reader')
        try {
          await scanner.start(
            { facingMode: 'environment' },
            { fps: 10, qrbox: { width: 250, height: 150 } },
            (decodedText) => {
              // Barcode read -> fill in and search
              input.value = decodedText.replace(/[^0-9Xx]/g, '')
              stopScan().then(() => {
                input.form.submit()
              })
            },
            () => {} // ignore "no code in frame" errors
          )
          running = true
          toggle.textContent = '✕ Close scanner'
        } catch (err) {
          showMsg('Could not access camera. Allow camera in your browser and try again.')
          reader.hidden = true
        }
      }

      async function stopScan() {
        if (scanner && running) {
          try { await scanner.stop() } catch (e) {}
          running = false
        }
        reader.hidden = true
        toggle.textContent = '📷 Scan barcode'
      }

      toggle.addEventListener('click', () => {
        if (running) stopScan()
        else startScan()
      })

      // ---- Register as family purchase: copy code, open Studio ----
      const famBtn = document.getElementById('family-register')
      const famMsg = document.getElementById('family-msg')
      if (famBtn) {
        famBtn.addEventListener('click', async () => {
          const code = (input.value || '').trim()
          const studio = famBtn.dataset.studio
          const url = studio + '/intent/create/type=familyPurchase;template=familyPurchase/'

          if (code) {
            try {
              await navigator.clipboard.writeText(code)
              famMsg.hidden = false
              famMsg.textContent = `Copied “${code}” — paste it into Name/Barcode in Studio.`
            } catch (e) {
              famMsg.hidden = false
              famMsg.style.color = 'var(--muted)'
              famMsg.textContent = `Could not copy automatically. Code: ${code}`
            }
          }
          window.open(url, '_blank', 'noopener')
        })
      }
    })()
  </script>
</Base>