---
import Base from '../layouts/Base.astro'
import { sanity } from '../lib/sanity'

const items = await sanity.fetch(`
  *[_type in ["album","game","merch"] && !(_id in path("drafts.**")) && defined(series)] {
    _id, _type, title, series, status
  }
`)

// Group by series
const groups: Record<string, any[]> = {}
for (const it of items) {
  const s = it.series || 'Uten serie'
  if (!groups[s]) groups[s] = []
  groups[s].push(it)
}

const seriesNames = Object.keys(groups).sort()
---
<Base title="Series">
  <div class="page-header">
    <h1>Series overview</h1>
    <span class="count">{seriesNames.length} series</span>
  </div>

  <p class="hint">Your collection grouped by Final Fantasy title. Tap a series to see the items, or use the reference links to explore what exists.</p>

  <input id="series-search" type="search" placeholder="Search series..." />

  <div class="series-list">
    {seriesNames.map((name) => {
      const list = groups[name]
      const owned = list.filter((i: any) => i.status === 'owned').length
      const wishlist = list.filter((i: any) => i.status === 'wishlist').length
      const q = encodeURIComponent(name)
      return (
        <details class="series-card" data-name={name.toLowerCase()}>
          <summary>
            <span class="series-name">{name}</span>
            <span class="series-counts">
              <span class="count-owned">{owned} owned</span>
              {wishlist > 0 && <span class="count-wish">{wishlist} wishlist</span>}
            </span>
          </summary>
          <div class="series-body">
            <div class="ref-links">
              <span class="ref-label">Explore:</span>
              <a target="_blank" rel="noopener" href={`https://finalfantasy.fandom.com/wiki/Special:Search?query=${q}`}>FF Wiki ↗</a>
              <a target="_blank" rel="noopener" href={`https://vgmdb.net/search?q=${q}`}>VGMdb ↗</a>
              <a target="_blank" rel="noopener" href={`https://www.1999.co.jp/eng/search?searchkey=${q}`}>Hobby Search ↗</a>
            </div>
            <div class="series-items">
              {list.map((i: any) => (
                <a class="series-item" href={`/${i._type}s/${i._id}`}>
                  <span class="item-icon">{i._type === 'album' ? '🎵' : i._type === 'game' ? '🎮' : '🗿'}</span>
                  <span class="item-title">{i.title}</span>
                  {i.status === 'wishlist' && <span class="tag wish">wishlist</span>}
                  {i.status === 'owned' && <span class="tag owned">owned</span>}
                </a>
              ))}
            </div>
          </div>
        </details>
      )
    })}
  </div>

  <style>
    .hint { font-size: 0.9rem; color: var(--muted); margin: 0.25rem 0 1.25rem; }
    #series-search { width: 100%; max-width: 360px; background: var(--surface); color: var(--text); border: 1px solid var(--border); padding: 0.6rem 0.75rem; border-radius: 6px; margin-bottom: 1.5rem; }

    .series-list { display: flex; flex-direction: column; gap: 0.6rem; }
    .series-card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; }
    .series-card summary { cursor: pointer; padding: 0.85rem 1rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; }
    .series-name { font-weight: 700; }
    .series-counts { display: flex; gap: 0.6rem; font-size: 0.8rem; }
    .count-owned { color: #2ecc71; font-weight: 600; }
    .count-wish { color: #3498db; font-weight: 600; }

    .series-body { padding: 0 1rem 1rem; }
    .ref-links { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; margin-bottom: 0.85rem; padding-bottom: 0.85rem; border-bottom: 1px solid var(--border); }
    .ref-label { font-size: 0.8rem; color: var(--muted); }
    .ref-links a { font-size: 0.8rem; background: var(--bg); color: var(--text); border: 1px solid var(--border); padding: 0.35rem 0.6rem; border-radius: 6px; text-decoration: none; }
    .ref-links a:hover { border-color: var(--accent); }

    .series-items { display: flex; flex-direction: column; }
    .series-item { display: flex; align-items: center; gap: 0.6rem; padding: 0.5rem 0; text-decoration: none; color: inherit; border-bottom: 1px solid var(--border); font-size: 0.9rem; }
    .series-item:last-child { border-bottom: none; }
    .series-item:hover { background: rgba(255,255,255,0.03); }
    .item-icon { flex-shrink: 0; }
    .item-title { flex: 1; min-width: 0; }
    .tag { padding: 0.2rem 0.5rem; border-radius: 5px; font-size: 0.72rem; font-weight: 700; }
    .tag.wish { background: #3498db; color: #04263d; }
    .tag.owned { background: #2ecc71; color: #06281a; }
  </style>

  <script>
    const search = document.querySelector('#series-search')
    search.addEventListener('input', () => {
      const q = search.value.toLowerCase()
      document.querySelectorAll('.series-card').forEach((card) => {
        card.style.display = card.dataset.name.includes(q) ? '' : 'none'
      })
    })
  </script>
</Base>