---
import Base from '../layouts/Base.astro'
import { sanity } from '../lib/sanity'

const items = await sanity.fetch(`
  *[_type in ["album","game","book","figure"] && !(_id in path("drafts.**")) && (defined(purchasePrice) || defined(purchasePriceYen))] {
    _id, _type, title, acquiredDate, purchasePrice, purchasePriceYen, status
  }
`)

// Fetch ALL trip settings, oldest first, so we can offer a switcher when there is more than one.
const allTrips = await sanity.fetch(`
  *[_type == "tripSettings"] | order(_createdAt asc) {
    _id, _createdAt, label, budgetNok, budgetYen, jpyToNokRate,
    childBudgets[]{ person, budgetNok, budgetYen }
  }
`)

// Fetch all family purchases (shopping list). Store name is pulled via the reference.
const familyPurchases = await sanity.fetch(`
  *[_type == "familyPurchase" && !(_id in path("drafts.**"))] {
    _id, name, person, status, priceNok, priceYen, purchaseDate,
    "tripId": trip._ref,
    "storeId": store._ref,
    "storeName": store->shopName
  }
`)

// Pick the active trip: from ?trip=<id> if valid, otherwise the first (oldest) one.
const requestedId = Astro.url.searchParams.get('trip')
const settings = allTrips.find((t) => t._id === requestedId) ?? allTrips[0] ?? null

// Build a readable label for each switcher button.
function tripLabel(trip, index) {
  if (trip.label) return trip.label
  if (trip._createdAt) return new Date(trip._createdAt).toLocaleDateString('en-GB')
  return `Trip ${index + 1}`
}

const activeTripId = settings?._id ?? null
const defaultRate = settings?.jpyToNokRate ?? 0.060
const budgetNok = settings?.budgetNok ?? null
const budgetYen = settings?.budgetYen ?? null
const childBudgets = settings?.childBudgets ?? []

// Family purchases for the active trip only.
const tripPurchases = familyPurchases.filter((p) => p.tripId === activeTripId)

// People shown in the family section = those with a trip budget, plus anyone with a purchase on this trip.
const tripPeople = childBudgets.map((c) => c.person).filter(Boolean)
const purchasePeople = [...new Set(tripPurchases.map((p) => p.person).filter(Boolean))]
const peopleList = [...new Set([...tripPeople, ...purchasePeople])]
---
<Base title="Spending">
  <div class="page-header">
    <h1>Spending</h1>
  </div>

  <p class="hint">FF collection totals are at the top. Family shopping list for the selected trip is below. Budgets and rate are set in Studio (Trip Settings).</p>

  {allTrips.length > 1 && (
    <nav class="trip-switcher">
      <span class="trip-switcher-label">Trip:</span>
      {allTrips.map((trip, index) => (
        <a
          href={`/spending?trip=${trip._id}`}
          class:list={['trip-btn', { active: trip._id === activeTripId }]}
        >{tripLabel(trip, index)}</a>
      ))}
    </nav>
  )}

  <div class="rate-row">
    <label>1 JPY = <input id="rate" type="number" step="0.0001" value={defaultRate} /> NOK</label>
  </div>

  <!-- ===== FF COLLECTION (your own spending) ===== -->
  <section class="section">
    <h2 class="section-title">My FF collection</h2>

    <div class="period-tools">
      <label>From <input id="from-date" type="date" /></label>
      <label>To <input id="to-date" type="date" /></label>
      <button id="period-30">Last 30 days</button>
      <button id="period-all">All time</button>
    </div>

    <div class="totals">
      <div class="total-card">
        <div class="total-label">Total (JPY)</div>
        <div class="total-num" id="total-yen">¥0</div>
      </div>
      <div class="total-card">
        <div class="total-label">JPY → NOK (est.)</div>
        <div class="total-num" id="total-yen-nok">0 kr</div>
      </div>
      <div class="total-card">
        <div class="total-label">Logged NOK</div>
        <div class="total-num" id="total-nok">0 kr</div>
      </div>
      <div class="total-card highlight">
        <div class="total-label">Combined (NOK)</div>
        <div class="total-num" id="total-combined">0 kr</div>
      </div>
      <div class="total-card">
        <div class="total-label">Items</div>
        <div class="total-num" id="total-count">0</div>
      </div>
    </div>

    {(budgetNok || budgetYen) && (
      <div class="budget-block" id="budget-block"
           data-budget-nok={budgetNok ?? ''}
           data-budget-yen={budgetYen ?? ''}>
        <div class="budget-head">
          <span>Trip budget</span>
          <span id="budget-label"></span>
        </div>
        <div class="budget-bar"><div class="budget-fill" id="budget-fill"></div></div>
        <div class="budget-meta" id="budget-meta"></div>
      </div>
    )}

    <div class="spend-list" id="spend-list"></div>
  </section>

  <!-- ===== FAMILY SHOPPING LIST (this trip only) ===== -->
  <section class="section">
    <h2 class="section-title">Family shopping — {settings ? (settings.label || 'this trip') : 'no trip'}</h2>

    {peopleList.length > 0 ? (
      <>
        <nav class="person-filter" id="person-filter">
          <span class="person-filter-label">Person:</span>
          <button class="person-btn active" data-person="">All</button>
          {peopleList.map((p) => (
            <button class="person-btn" data-person={p}>{p}</button>
          ))}
        </nav>

        <div class="child-summary" id="child-summary"></div>

        <div class="store-wrap" id="store-wrap">
          <h3 class="store-title">Tax-free by store / day</h3>
          <div class="store-list" id="store-list"></div>
          <p class="store-note">Assumes shelf prices include 10% tax. Tax-free applies at ¥5,000+ (pre-tax) per store per day. Counts everyone's purchases for this trip.</p>
        </div>

        <div class="spend-list" id="family-list"></div>
      </>
    ) : (
      <p class="hint">No family purchases or per-child budgets for this trip yet. Add them in Studio (Family Purchases / Trip Settings).</p>
    )}
  </section>

  <script define:vars={{ items, budgetNok, budgetYen, childBudgets, peopleList, tripPurchases }}>
    const fromInput = document.querySelector('#from-date')
    const toInput = document.querySelector('#to-date')
    const rateInput = document.querySelector('#rate')
    const list = document.querySelector('#spend-list')
    const totalYenEl = document.querySelector('#total-yen')
    const totalYenNokEl = document.querySelector('#total-yen-nok')
    const totalNokEl = document.querySelector('#total-nok')
    const totalCombinedEl = document.querySelector('#total-combined')
    const totalCountEl = document.querySelector('#total-count')

    const budgetBlock = document.querySelector('#budget-block')
    const budgetFill = document.querySelector('#budget-fill')
    const budgetMeta = document.querySelector('#budget-meta')
    const budgetLabel = document.querySelector('#budget-label')

    const personFilter = document.querySelector('#person-filter')
    const childSummary = document.querySelector('#child-summary')
    const familyList = document.querySelector('#family-list')
    const storeWrap = document.querySelector('#store-wrap')
    const storeList = document.querySelector('#store-list')

    let selectedPerson = '' // '' means "All"

    const TAX_RATE = 0.10
    const PRETAX_THRESHOLD = 5000

    function fmtYen(n) { return '¥' + Math.round(n).toLocaleString('en-US') }
    function fmtNok(n) { return Math.round(n).toLocaleString('nb-NO') + ' kr' }

    function inRange(dateStr, from, to) {
      if (!dateStr) return false
      if (from && dateStr < from) return false
      if (to && dateStr > to) return false
      return true
    }

    // Resolve a budget (given in NOK and/or JPY) into both currencies using the rate.
    function budgetBoth(bNok, bYen, rate) {
      let nok = null, yen = null, nokExplicit = false, yenExplicit = false
      if (bNok) { nok = Number(bNok); yen = rate > 0 ? nok / rate : null; nokExplicit = true }
      else if (bYen) { yen = Number(bYen); nok = yen * rate; yenExplicit = true }
      return { nok, yen, nokExplicit, yenExplicit }
    }

    function childBudgetFor(person) {
      const entry = (childBudgets || []).find((c) => c.person === person)
      return entry ? { nok: entry.budgetNok ?? null, yen: entry.budgetYen ?? null } : { nok: null, yen: null }
    }

    // ---- FF collection section (unchanged behaviour) ----
    function updateCollection() {
      const from = fromInput.value
      const to = toInput.value
      const rate = Number(rateInput.value) || 0
      const filtered = (!from && !to)
        ? items.slice()
        : items.filter((i) => inRange(i.acquiredDate, from, to))

      let yen = 0, nok = 0
      filtered.forEach((i) => {
        if (i.purchasePriceYen) yen += Number(i.purchasePriceYen)
        if (i.purchasePrice) nok += Number(i.purchasePrice)
      })

      const yenAsNok = yen * rate
      const combinedNok = yenAsNok + nok
      totalYenEl.textContent = fmtYen(yen)
      totalYenNokEl.textContent = fmtNok(yenAsNok)
      totalNokEl.textContent = fmtNok(nok)
      totalCombinedEl.textContent = fmtNok(combinedNok)
      totalCountEl.textContent = filtered.length

      if (budgetBlock) {
        const b = budgetBoth(budgetNok, budgetYen, rate)
        if (b.nok && b.nok > 0) {
          const pct = Math.min(100, (combinedNok / b.nok) * 100)
          const remaining = b.nok - combinedNok
          budgetFill.style.width = pct.toFixed(1) + '%'
          budgetFill.classList.toggle('over', combinedNok > b.nok)

          const nokPart = fmtNok(b.nok) + (b.nokExplicit ? '' : ' est.')
          const yenPart = b.yen ? fmtYen(b.yen) + (b.yenExplicit ? '' : ' est.') : ''
          budgetLabel.textContent = [nokPart, yenPart].filter(Boolean).join(' · ')

          if (remaining >= 0) {
            const remYen = rate > 0 ? remaining / rate : 0
            budgetMeta.textContent = `${fmtNok(combinedNok)} spent · ${fmtNok(remaining)} left (${fmtYen(remYen)})`
            budgetMeta.classList.remove('over')
          } else {
            const overYen = rate > 0 ? (-remaining) / rate : 0
            budgetMeta.textContent = `${fmtNok(combinedNok)} spent · ${fmtNok(-remaining)} over (${fmtYen(overYen)})`
            budgetMeta.classList.add('over')
          }
        }
      }

      const sorted = filtered.slice().sort((a, b) => (b.acquiredDate || '').localeCompare(a.acquiredDate || ''))
      list.innerHTML = sorted.map((i) => {
        const icon = i._type === 'album' ? '🎵' : i._type === 'game' ? '🎮' : i._type === 'book' ? '📚' : '🗿'
        const yenStr = i.purchasePriceYen ? fmtYen(i.purchasePriceYen) : ''
        const nokStr = i.purchasePrice ? fmtNok(i.purchasePrice) : ''
        const price = [yenStr, nokStr].filter(Boolean).join(' · ')
        return `<div class="spend-row">
          <span class="spend-icon">${icon}</span>
          <span class="spend-title">${i.title || ''}</span>
          <span class="spend-date">${i.acquiredDate || ''}</span>
          <span class="spend-price">${price}</span>
        </div>`
      }).join('')
    }

    // ---- Family section (this trip only; bought vs planned; respects selectedPerson) ----
    function updateFamily() {
      if (!childSummary) return
      const rate = Number(rateInput.value) || 0
      const peopleToShow = selectedPerson ? [selectedPerson] : (peopleList || [])

      const rows = peopleToShow.map((person) => {
        const its = (tripPurchases || []).filter((p) => p.person === person)
        let boughtNok = 0, plannedNok = 0
        its.forEach((p) => {
          const nok = (p.priceYen ? Number(p.priceYen) * rate : 0) + (p.priceNok ? Number(p.priceNok) : 0)
          if (p.status === 'bought') boughtNok += nok
          else plannedNok += nok
        })
        const cb = childBudgetFor(person)
        const b = budgetBoth(cb.nok, cb.yen, rate)
        return { person, boughtNok, plannedNok, count: its.length, b }
      })

      childSummary.innerHTML = rows.map((r) => {
        const hasBudget = r.b.nok && r.b.nok > 0
        let bar = ''
        let over = false
        let meta = `${fmtNok(r.boughtNok)} spent`
        if (r.plannedNok > 0) meta += ` · +${fmtNok(r.plannedNok)} planned`
        meta += ` · ${r.count} item${r.count === 1 ? '' : 's'}`

        if (hasBudget) {
          const pct = Math.min(100, (r.boughtNok / r.b.nok) * 100)
          over = r.boughtNok > r.b.nok
          const remaining = r.b.nok - r.boughtNok
          bar = `<div class="cs-bar"><div class="cs-fill ${over ? 'over' : ''}" style="width:${pct.toFixed(1)}%"></div></div>`
          const budLabel = fmtNok(r.b.nok) + (r.b.nokExplicit ? '' : ' est.')
          const remPart = remaining >= 0 ? `${fmtNok(remaining)} left` : `${fmtNok(-remaining)} over`
          const planPart = r.plannedNok > 0 ? ` · +${fmtNok(r.plannedNok)} planned` : ''
          meta = `${fmtNok(r.boughtNok)} / ${budLabel} · ${remPart}${planPart}`
        }

        return `<div class="cs-row">
          <div class="cs-head">
            <span class="cs-name">${r.person}</span>
            <span class="cs-spent ${over ? 'over' : ''}">${meta}</span>
          </div>
          ${bar}
        </div>`
      }).join('')
      
      // Family purchase list, filtered by selected person. Always shows both currencies.
      if (familyList) {
        const visible = selectedPerson
          ? (tripPurchases || []).filter((p) => p.person === selectedPerson)
          : (tripPurchases || [])
        const sorted = visible.slice().sort((a, b) => (a.person || '').localeCompare(b.person || ''))
        familyList.innerHTML = sorted.map((p) => {
          const hasYen = p.priceYen != null && p.priceYen !== ''
          const hasNok = p.priceNok != null && p.priceNok !== ''

          // Show yen and NOK side by side, deriving whichever is missing from the rate.
          let yenStr = ''
          let nokStr = ''
          if (hasYen) {
            yenStr = fmtYen(Number(p.priceYen))
            nokStr = hasNok ? fmtNok(Number(p.priceNok)) : fmtNok(Number(p.priceYen) * rate) + ' est.'
          } else if (hasNok) {
            nokStr = fmtNok(Number(p.priceNok))
            yenStr = rate > 0 ? fmtYen(Number(p.priceNok) / rate) + ' est.' : ''
          }
          const price = [yenStr, nokStr].filter(Boolean).join(' · ')

          const icon = p.status === 'bought' ? '✅' : '🛒'
          const store = p.storeName ? `<span class="spend-store">${p.storeName}</span>` : ''
          return `<div class="spend-row">
            <span class="spend-icon">${icon}</span>
            <span class="spend-title">${p.name || ''}</span>
            <span class="spend-who">${p.person || ''}</span>
            ${store}
            <span class="spend-price">${price}</span>
          </div>`
        }).join('')
      }
    }

    // ---- Tax-free tracker, grouped by store + day (all people, this trip) ----
    function updateStores() {
      if (!storeWrap) return
      const groups = {}
      ;(tripPurchases || []).forEach((p) => {
        if (!p.priceYen) return
        const storeName = (p.storeName && p.storeName.trim()) ? p.storeName.trim() : '— No store —'
        const day = p.purchaseDate || '— No date —'
        const key = storeName + '||' + day
        if (!groups[key]) groups[key] = { storeName, day, incl: 0 }
        groups[key].incl += Number(p.priceYen)
      })

      const keys = Object.keys(groups).sort((a, b) => {
        // Sort by date desc, then store name.
        const ga = groups[a], gb = groups[b]
        if (ga.day !== gb.day) return gb.day.localeCompare(ga.day)
        return ga.storeName.localeCompare(gb.storeName)
      })

      if (!keys.length) { storeWrap.style.display = 'none'; return }
      storeWrap.style.display = ''

      storeList.innerHTML = keys.map((key) => {
        const g = groups[key]
        const incl = g.incl
        const preTax = incl / (1 + TAX_RATE)
        const hasStore = g.storeName !== '— No store —'
        const reached = preTax >= PRETAX_THRESHOLD
        let cls = '', meta

        if (!hasStore) {
          meta = `${fmtYen(incl)} · assign a store to track tax-free`
        } else if (reached) {
          const saved = incl - preTax
          cls = 'ok'
          meta = `${fmtYen(incl)} · tax-free reached · save ~${fmtYen(saved)}`
        } else {
          const neededIncl = PRETAX_THRESHOLD * (1 + TAX_RATE) - incl
          meta = `${fmtYen(incl)} · ${fmtYen(neededIncl)} more to reach tax-free`
        }

        return `<div class="store-row ${cls}">
          <span class="store-name">${g.storeName} <span class="store-day">${g.day}</span></span>
          <span class="store-meta">${meta}</span>
        </div>`
      }).join('')
    }

    function update() {
      updateCollection()
      updateFamily()
      updateStores()
    }

    if (personFilter) {
      personFilter.querySelectorAll('.person-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          selectedPerson = btn.dataset.person || ''
          personFilter.querySelectorAll('.person-btn').forEach((b) => b.classList.toggle('active', b === btn))
          updateFamily()
        })
      })
    }

    document.querySelector('#period-30').addEventListener('click', () => {
      const now = new Date()
      const past = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000)
      toInput.value = now.toISOString().split('T')[0]
      fromInput.value = past.toISOString().split('T')[0]
      update()
    })
    document.querySelector('#period-all').addEventListener('click', () => {
      fromInput.value = ''
      toInput.value = ''
      update()
    })
    fromInput.addEventListener('change', update)
    toInput.addEventListener('change', update)
    rateInput.addEventListener('input', update)

    update()
  </script>

  <style>
    .hint { font-size: 0.9rem; color: var(--muted); margin: 0.5rem 0 1.25rem; }

    .trip-switcher { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; margin-bottom: 1.25rem; }
    .trip-switcher-label { font-size: 0.85rem; color: var(--muted); }
    .person-filter { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; margin-bottom: 1.25rem; }
    .person-filter-label { font-size: 0.85rem; color: var(--muted); }

    .trip-btn,
    .person-btn {
      padding: 0.45rem 0.95rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: var(--surface);
      color: var(--text);
      font-size: 0.85rem;
      font-weight: 500;
      line-height: 1;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.25);
      transition: background 0.15s, border-color 0.15s, transform 0.05s;
    }

    .trip-btn:hover,
    .person-btn:hover {
      border-color: var(--accent);
      background: color-mix(in srgb, var(--accent) 12%, var(--surface));
    }

    .trip-btn:active,
    .person-btn:active {
      transform: translateY(1px);
    }

    .trip-btn.active,
    .person-btn.active {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
      box-shadow: 0 2px 6px color-mix(in srgb, var(--accent) 45%, transparent);
      font-weight: 600;
    }

    .section { margin-bottom: 2.5rem; }
    .section-title { font-size: 1.1rem; margin: 0 0 1rem; padding-bottom: 0.4rem; border-bottom: 1px solid var(--border); }

    .period-tools { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; margin-bottom: 1rem; }
    .period-tools label { font-size: 0.85rem; color: var(--muted); display: flex; gap: 0.4rem; align-items: center; }
    .period-tools input { background: var(--surface); color: var(--text); border: 1px solid var(--border); padding: 0.5rem; border-radius: 6px; }
    .period-tools button { background: var(--surface); color: var(--text); border: 1px solid var(--accent); padding: 0.5rem 0.85rem; border-radius: 6px; cursor: pointer; font-size: 0.85rem; }

    .rate-row { margin-bottom: 1.5rem; }
    .rate-row label { font-size: 0.85rem; color: var(--muted); display: flex; gap: 0.4rem; align-items: center; }
    .rate-row input { background: var(--surface); color: var(--text); border: 1px solid var(--border); padding: 0.5rem; border-radius: 6px; width: 100px; }

    .totals { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
    .total-card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 1rem 1.25rem; flex: 1; min-width: 120px; }
    .total-card.highlight { border-color: var(--accent); }
    .total-label { font-size: 0.8rem; color: var(--muted); margin-bottom: 0.35rem; }
    .total-num { font-size: 1.4rem; font-weight: 700; }

    .budget-block { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 1rem 1.25rem; margin-bottom: 2rem; }
    .budget-head { display: flex; justify-content: space-between; font-size: 0.9rem; margin-bottom: 0.6rem; font-weight: 600; }
    .budget-bar { background: var(--border); border-radius: 999px; height: 12px; overflow: hidden; }
    .budget-fill { background: #2ecc71; height: 100%; width: 0%; transition: width 0.3s; }
    .budget-fill.over { background: #e74c3c; }
    .budget-meta { font-size: 0.85rem; color: var(--muted); margin-top: 0.5rem; }
    .budget-meta.over { color: #e74c3c; font-weight: 600; }

    .child-summary { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem; }
    .cs-row { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 0.75rem 1rem; }
    .cs-head { display: flex; justify-content: space-between; gap: 0.75rem; font-size: 0.85rem; margin-bottom: 0.5rem; }
    .cs-name { font-weight: 600; }
    .cs-spent { color: var(--muted); text-align: right; }
    .cs-spent.over { color: #e74c3c; font-weight: 600; }
    .cs-bar { background: var(--border); border-radius: 999px; height: 8px; overflow: hidden; }
    .cs-fill { background: #2ecc71; height: 100%; width: 0%; transition: width 0.3s; }
    .cs-fill.over { background: #e74c3c; }

    .store-wrap { margin-bottom: 1.5rem; }
    .store-title { font-size: 0.95rem; margin: 0 0 0.6rem; }
    .store-list { display: flex; flex-direction: column; gap: 0.5rem; }
    .store-row { display: flex; justify-content: space-between; gap: 0.75rem; align-items: center; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 0.6rem 0.9rem; font-size: 0.85rem; }
    .store-row.ok { border-color: #2ecc71; }
    .store-name { font-weight: 600; }
    .store-day { font-weight: 400; color: var(--muted); font-size: 0.75rem; margin-left: 0.4rem; }
    .store-meta { color: var(--muted); text-align: right; }
    .store-row.ok .store-meta { color: #2ecc71; }
    .store-note { font-size: 0.75rem; color: var(--muted); margin: 0.6rem 0 0; }

    .spend-list { display: flex; flex-direction: column; border-top: 1px solid var(--border); }
